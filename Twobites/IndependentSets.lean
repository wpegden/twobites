    {v : Fin n} : v ‚àà C.X I (Sum.inl r) ‚Üî v ‚àà I ‚àß C.redBase.Adj r (C.redProj v) := by
  classical
  simp [X]

@[simp] theorem mem_X_blue (C : ConstructionData n m) {I : Finset (Fin n)} {b : Fin m}
    {v : Fin n} : v ‚àà C.X I (Sum.inr b) ‚Üî v ‚àà I ‚àß C.blueBase.Adj b (C.blueProj v) := by
