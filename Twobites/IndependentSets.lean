  ¬∑ rintro ‚ü®v, hvI, hAdj, hrv‚ü©
    refine Finset.mem_image.2 ‚ü®v, ?_, hrv‚ü©
    exact (C.mem_X_blue).2 ‚ü®hvI, hAdj‚ü©

@[simp] theorem mem_blueProjectionImage_inl (C : ConstructionData n m) {I : Finset (Fin n)}
    {r b : Fin m} :
    b ‚àà C.blueProjectionImage I (Sum.inl r) ‚Üî
      ‚àÉ v ‚àà I, C.redBase.Adj r (C.redProj v) ‚àß C.blueProj v = b := by
