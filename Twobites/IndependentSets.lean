    (C : ConstructionData n m) (I : Finset (Fin n)) {Œµ : ‚Ñù} {N : ‚Ñï}
    (hopen : N ‚â§ (C.baseOpenPairSet I).card) :
    N - I.card * (C.section4F1 I ‚à™ C.section4F2 I Œµ).card ‚â§
      (C.unrevealedBaseOpenPairSet I (C.section4F I Œµ)).card := by
  have hbase :
      N - (C.revealedBaseOpenPairSet I (C.section4F I Œµ)).card ‚â§
        (C.unrevealedBaseOpenPairSet I (C.section4F I Œµ)).card :=
    C.openPair_lower_bound_sub_reveal_budget_le_unrevealed I (C.section4F I Œµ) hopen
