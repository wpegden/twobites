theorem disjoint_HPart_LPart_union_MPart_union_SPart_of_thresholds
    (C : ConstructionData n m) (I : Finset (Fin n)) {Œµ : ‚Ñù}
    (ht21 : Twobites.paperT2 Œµ n ‚â§ Twobites.paperT1 n)
    (ht32 : Twobites.paperT3 Œµ n ‚â§ Twobites.paperT2 Œµ n) :
    Disjoint (C.HPart I) (C.LPart I Œµ ‚à™ C.MPart I Œµ ‚à™ C.SPart I Œµ) := by
  refine Finset.disjoint_left.2 ?_
  intro x hxH hxA
  rcases Finset.mem_union.1 hxA with hxLM | hxS
  ¬∑ rcases Finset.mem_union.1 hxLM with hxL | hxM
    ¬∑ exact (Finset.disjoint_left.1 (C.disjoint_HPart_LPart I Œµ)) hxH hxL
    ¬∑ exact (Finset.disjoint_left.1 (C.disjoint_HPart_MPart I ht21)) hxH hxM
  ¬∑ have ht31 : Twobites.paperT3 Œµ n ‚â§ Twobites.paperT1 n := le_trans ht32 ht21
    exact (Finset.disjoint_left.1 (C.disjoint_HPart_SPart I ht31)) hxH hxS

theorem outside_section4F_subset_LPart_union_MPart_union_SPart_of_HPart_subset_section4F2
    (C : ConstructionData n m) (I : Finset (Fin n)) {Œµ : ‚Ñù}
    (hHsubset : C.baseImage I ‚à© C.HPart I ‚äÜ C.section4F2 I Œµ) :
    (Finset.univ.filter fun x : BaseVertex m => x ‚àâ C.section4F I Œµ) ‚äÜ
      C.LPart I Œµ ‚à™ C.MPart I Œµ ‚à™ C.SPart I Œµ := by
  intro x hx
  have hxNotF : x ‚àâ C.section4F I Œµ := (Finset.mem_filter.1 hx).2
  have hxBase : x ‚àà C.baseImage I := by
    by_contra hxBase
    exact hxNotF <| C.mem_section4F.2 <| Or.inl <| C.mem_section4F0.2 ‚ü®by simp, hxBase‚ü©
  have hxNotH : x ‚àâ C.HPart I := by
    intro hxH
    have hxF2 : x ‚àà C.section4F2 I Œµ := hHsubset (by simp [hxBase, hxH])
    exact hxNotF <| C.mem_section4F.2 <| Or.inr <| Or.inr hxF2
  rcases C.mem_HPart_or_mem_LPart_or_mem_MPart_or_mem_SPart I Œµ x with hxH | hxL | hxM | hxS
  ¬∑ exact False.elim (hxNotH hxH)
  ¬∑ simpa [Finset.mem_union] using
      (Or.inl hxL : x ‚àà C.LPart I Œµ ‚à® x ‚àà C.MPart I Œµ ‚à® x ‚àà C.SPart I Œµ)
  ¬∑ simpa [Finset.mem_union] using
      (Or.inr (Or.inl hxM) : x ‚àà C.LPart I Œµ ‚à® x ‚àà C.MPart I Œµ ‚à® x ‚àà C.SPart I Œµ)
  ¬∑ simpa [Finset.mem_union] using
      (Or.inr (Or.inr hxS) : x ‚àà C.LPart I Œµ ‚à® x ‚àà C.MPart I Œµ ‚à® x ‚àà C.SPart I Œµ)

theorem outside_section4F_blue_subset_LMS_filter_isBlue_of_HPart_subset_section4F2
    (C : ConstructionData n m) (I : Finset (Fin n)) {Œµ : ‚Ñù}
