theorem section4UChoiceSet_card_le_choose_mul_choose
    (C : ConstructionData n m) {I : Finset (Fin n)} {A : Finset (BaseVertex m)} {uR uB : ‚Ñï} :
    (C.section4UChoiceSet I A uR uB).card ‚â§
      (C.redProjectionPairCount I
        ((Finset.univ.filter fun b : Fin m => Sum.inr b ‚àâ A).image Sum.inr)).choose uR *
