  have hdel : C.redDeleted v w := by
    by_contra hdel
    exact hnotFinal ((C.finalGraph_adj_iff).2 <|
      Or.inl ((C.retainedRed_adj_iff).2 ‚ü®hred, hdel‚ü©))
  rcases hdel with ‚ü®u, hmono | hmixed‚ü©
  ¬∑ exact (hopenPlus' (C.closedPairPlus_of_redMonochromaticDeletionWitness hvI hwI hvw hmono)).elim
  ¬∑ rcases hmixed with ‚ü®huv, huw, -‚ü©
    have hnotA : Sum.inr (C.blueProj u) ‚àâ A := by
      intro hxA
      exact hopenA (C.closedPairOn_of_mem hxA
        ((C.mem_X_blue).2 ‚ü®hvI, huv‚ü©)
        ((C.mem_X_blue).2 ‚ü®hwI, huw‚ü©) hvw)
    refine Finset.mem_biUnion.2 ‚ü®C.blueProj u, by simpa using hnotA, ?_‚ü©
    refine Finset.mem_image.2 ‚ü®(C.redProj v, C.redProj w), ?_, rfl‚ü©
    refine Finset.mem_offDiag.2 ‚ü®?_, ?_, C.redProj_ne_of_redLift_adj hred‚ü©
    ¬∑ refine Finset.mem_image.2 ‚ü®v, (C.mem_X_blue).2 ‚ü®hvI, huv‚ü©, rfl‚ü©
    ¬∑ refine Finset.mem_image.2 ‚ü®w, (C.mem_X_blue).2 ‚ü®hwI, huw‚ü©, rfl‚ü©

