theorem sum_choose_two_le_choose_two_cap_add_choose_two_sub_of_le {Œ± : Type*} (A : Finset Œ±)
    (f : Œ± ‚Üí ‚Ñï) {cap : ‚Ñï} (hcap : ‚àÄ x ‚àà A, f x ‚â§ cap) (hsum : cap ‚â§ ‚àë x ‚àà A, f x) :
    ‚àë x ‚àà A, (f x).choose 2 ‚â§ cap.choose 2 + ((‚àë x ‚àà A, f x) - cap).choose 2 := by
  classical
  induction A using Finset.induction_on with
  | empty =>
      have hcap_le : cap ‚â§ 0 := by
        simpa using hsum
      have hcap0 : cap = 0 := Nat.eq_zero_of_le_zero hcap_le
      simp [hcap0]
  | @insert a s ha ih =>
      have haCap : f a ‚â§ cap := hcap a (by simp [ha])
      by_cases hs : cap ‚â§ ‚àë x ‚àà s, f x
      ¬∑ have hsCap : ‚àÄ x ‚àà s, f x ‚â§ cap := by
          intro x hx
          exact hcap x (Finset.mem_insert_of_mem hx)
        calc
          ‚àë x ‚àà insert a s, (f x).choose 2 = (f a).choose 2 + ‚àë x ‚àà s, (f x).choose 2 := by
            simp [ha]
          _ ‚â§ (f a).choose 2 + (cap.choose 2 + ((‚àë x ‚àà s, f x) - cap).choose 2) := by
            gcongr
            exact ih hsCap hs
          _ = cap.choose 2 + ((f a).choose 2 + ((‚àë x ‚àà s, f x) - cap).choose 2) := by
            ac_rfl
          _ ‚â§ cap.choose 2 + (f a + ((‚àë x ‚àà s, f x) - cap)).choose 2 := by
            gcongr
            exact choose_two_add_le_choose_two_sum _ _
          _ = cap.choose 2 + ((‚àë x ‚àà insert a s, f x) - cap).choose 2 := by
            rw [Finset.sum_insert ha]
            rw [Nat.add_sub_assoc hs]
      ¬∑ have hslt : ‚àë x ‚àà s, f x < cap := Nat.lt_of_not_ge hs
        have hs' : ‚àë x ‚àà s, f x ‚â§ cap := le_of_lt hslt
        have hsumInsert : cap ‚â§ f a + ‚àë x ‚àà s, f x := by
          simpa [Finset.sum_insert, ha] using hsum
        calc
          ‚àë x ‚àà insert a s, (f x).choose 2 = (f a).choose 2 + ‚àë x ‚àà s, (f x).choose 2 := by
            simp [ha]
          _ ‚â§ (f a).choose 2 + (‚àë x ‚àà s, f x).choose 2 := by
            gcongr
            exact sum_choose_two_le_choose_two_sum s f
          _ ‚â§ cap.choose 2 + (f a + ‚àë x ‚àà s, f x - cap).choose 2 := by
            exact choose_two_add_le_choose_two_cap_add_choose_two_sub haCap hs' hsumInsert
          _ = cap.choose 2 + ((‚àë x ‚àà insert a s, f x) - cap).choose 2 := by
            rw [Finset.sum_insert ha]

