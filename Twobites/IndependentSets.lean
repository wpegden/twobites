theorem
    redProjectionImage_filter_section4F1_image_inl_eq_baseNeighborSet_inter_section4F1
    (C : ConstructionData n m) (I : Finset (Fin n)) (r : Fin m) :
    ((C.redProjectionImage I (Sum.inl r)).filter fun r' => Sum.inl r' ‚àà C.section4F1 I).image
        Sum.inl =
      C.baseNeighborSet (Sum.inl r) ‚à© C.section4F1 I := by
  ext x
  cases x with
  | inl r' =>
      constructor
      ¬∑ intro hx
        rcases Finset.mem_image.1 hx with ‚ü®s, hs, hsEq‚ü©
        rcases Finset.mem_filter.1 hs with ‚ü®hsProj, hsF1‚ü©
        have hAdj : C.redBase.Adj r s := (C.mem_redProjectionImage_inl.1 hsProj).1
        exact hsEq ‚ñ∏ Finset.mem_inter.2 ‚ü®by simpa using hAdj, hsF1‚ü©
      ¬∑ intro hx
        rcases Finset.mem_inter.1 hx with ‚ü®hAdjMem, hF1‚ü©
        have hAdj : C.redBase.Adj r r' := (C.mem_baseNeighborSet_inl_inl.1 hAdjMem)
        have hsProj : r' ‚àà C.redProjectionImage I (Sum.inl r) := by
          exact (C.mem_redProjectionImage_inl.2
            ‚ü®hAdj, C.mem_baseImage_inl.1 ((C.mem_section4F1.1 hF1).1)‚ü©)
        exact Finset.mem_image.2 ‚ü®r', Finset.mem_filter.2 ‚ü®hsProj, hF1‚ü©, rfl‚ü©
  | inr b =>
      simp

theorem
    blueProjectionImage_filter_section4F1_image_inr_eq_baseNeighborSet_inter_section4F1
    (C : ConstructionData n m) (I : Finset (Fin n)) (b : Fin m) :
    ((C.blueProjectionImage I (Sum.inr b)).filter fun b' => Sum.inr b' ‚àà C.section4F1 I).image
        Sum.inr =
      C.baseNeighborSet (Sum.inr b) ‚à© C.section4F1 I := by
  ext x
  cases x with
  | inl r =>
      simp
  | inr b' =>
      constructor
      ¬∑ intro hx
        rcases Finset.mem_image.1 hx with ‚ü®s, hs, hsEq‚ü©
        rcases Finset.mem_filter.1 hs with ‚ü®hsProj, hsF1‚ü©
        have hAdj : C.blueBase.Adj b s := (C.mem_blueProjectionImage_inr.1 hsProj).1
        exact hsEq ‚ñ∏ Finset.mem_inter.2 ‚ü®by simpa using hAdj, hsF1‚ü©
      ¬∑ intro hx
        rcases Finset.mem_inter.1 hx with ‚ü®hAdjMem, hF1‚ü©
        have hAdj : C.blueBase.Adj b b' := (C.mem_baseNeighborSet_inr_inr.1 hAdjMem)
        have hsProj : b' ‚àà C.blueProjectionImage I (Sum.inr b) := by
          exact (C.mem_blueProjectionImage_inr.2
            ‚ü®hAdj, C.mem_baseImage_inr.1 ((C.mem_section4F1.1 hF1).1)‚ü©)
        exact Finset.mem_image.2 ‚ü®b', Finset.mem_filter.2 ‚ü®hsProj, hF1‚ü©, rfl‚ü©

theorem disjoint_redFiber_inter (C : ConstructionData n m) (I : Finset (Fin n))
    {r r' : Fin m} (hrr' : r ‚âÝ r') :
    Disjoint (C.redFiber r ‚à© I) (C.redFiber r' ‚à© I) := by
  rw [Finset.disjoint_left]
  intro v hv hv'
  rcases Finset.mem_inter.1 hv with ‚ü®hvFiber, _‚ü©
  rcases Finset.mem_inter.1 hv' with ‚ü®hvFiber', _‚ü©
  have h1 : C.redProj v = r := C.mem_redFiber.1 hvFiber
  have h2 : C.redProj v = r' := C.mem_redFiber.1 hvFiber'
  exact hrr' (h1.symm.trans h2)

theorem disjoint_blueFiber_inter (C : ConstructionData n m) (I : Finset (Fin n))
    {b b' : Fin m} (hbb' : b ‚âÝ b') :
    Disjoint (C.blueFiber b ‚à© I) (C.blueFiber b' ‚à© I) := by
  rw [Finset.disjoint_left]
  intro v hv hv'
  rcases Finset.mem_inter.1 hv with ‚ü®hvFiber, _‚ü©
  rcases Finset.mem_inter.1 hv' with ‚ü®hvFiber', _‚ü©
  have h1 : C.blueProj v = b := C.mem_blueFiber.1 hvFiber
  have h2 : C.blueProj v = b' := C.mem_blueFiber.1 hvFiber'
  exact hbb' (h1.symm.trans h2)

theorem X_red_eq_biUnion_redFiber_inter (C : ConstructionData n m) (I : Finset (Fin n))
    (r : Fin m) :
    C.X I (Sum.inl r) =
      (C.redProjectionImage I (Sum.inl r)).biUnion fun r' => C.redFiber r' ‚à© I := by
  ext v
  constructor
  ¬∑ intro hv
    refine Finset.mem_biUnion.2 ‚ü®C.redProj v, ?_, ?_‚ü©
    ¬∑ exact Finset.mem_image.2 ‚ü®v, hv, rfl‚ü©
    ¬∑ rcases (C.mem_X_red).1 hv with ‚ü®hvI, _‚ü©
      simp [hvI]
  ¬∑ intro hv
    rcases Finset.mem_biUnion.1 hv with ‚ü®r', hr', hv'‚ü©
    rcases Finset.mem_inter.1 hv' with ‚ü®hvFiber, hvI‚ü©
    have hAdj : C.redBase.Adj r r' := (C.mem_redProjectionImage_inl.1 hr').1
    have hAdj' : C.redBase.Adj r (C.redProj v) := by
      rwa [C.mem_redFiber.1 hvFiber]
    exact (C.mem_X_red).2 ‚ü®hvI, hAdj'‚ü©

theorem X_blue_eq_biUnion_blueFiber_inter (C : ConstructionData n m) (I : Finset (Fin n))
    (b : Fin m) :
    C.X I (Sum.inr b) =
      (C.blueProjectionImage I (Sum.inr b)).biUnion fun b' => C.blueFiber b' ‚à© I := by
  ext v
  constructor
  ¬∑ intro hv
    refine Finset.mem_biUnion.2 ‚ü®C.blueProj v, ?_, ?_‚ü©
    ¬∑ exact Finset.mem_image.2 ‚ü®v, hv, rfl‚ü©
    ¬∑ rcases (C.mem_X_blue).1 hv with ‚ü®hvI, _‚ü©
      simp [hvI]
  ¬∑ intro hv
    rcases Finset.mem_biUnion.1 hv with ‚ü®b', hb', hv'‚ü©
