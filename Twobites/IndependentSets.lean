/-- A cleaner version of the previous outer-event wrapper where the explicit exponent has already
been rewritten into the main `((x_R+x_B-1)/2) k log n` term plus the remaining lower-order
corrections, and the nonpositive `x \log x` pieces are dropped using the image-card scales
`x_R,x_B ‚â§ 1`. -/
theorem paper_ri_chooseOuterEventMass_le_exp_of_mainRemainder_of_images
    (C : ConstructionData n m) (I : Finset (Fin n))
    {Œµ xR xB outerExp : ‚Ñù}
    (hn : 1 < n)
    (hloglog : 2 ‚â§ Real.log (Real.log (n : ‚Ñù)))
    (hŒµ : 0 ‚â§ Œµ) (hŒµquarter : Œµ ‚â§ (1 / 4 : ‚Ñù))
    (hI : I.card ‚â§ Twobites.paperKNat (1 + Œµ) n)
    (hkone : 1 ‚â§ Twobites.paperK (1 + Œµ) n)
    (hsum2 : xR + xB ‚â§ 2)
    (hk : Twobites.paperKNat (1 + Œµ) n ‚â§ Twobites.paperMNat n * Twobites.paperMNat n)
    (hredM : (C.redImage I).card ‚â§ Twobites.paperMNat n)
    (hblueM : (C.blueImage I).card ‚â§ Twobites.paperMNat n)
    (hkprod :
      Twobites.paperKNat (1 + Œµ) n ‚â§ (C.redImage I).card * (C.blueImage I).card)
    (hhalf :
      2 * Twobites.paperKNat (1 + Œµ) n ‚â§ Twobites.paperMNat n * Twobites.paperMNat n + 1)
    (hredEq : ((C.redImage I).card : ‚Ñù) = xR * (Twobites.paperKNat (1 + Œµ) n : ‚Ñù))
    (hblueEq : ((C.blueImage I).card : ‚Ñù) = xB * (Twobites.paperKNat (1 + Œµ) n : ‚Ñù))
    (hxRpos : 0 < xR) (hxBpos : 0 < xB)
    (houterExp :
      ((((xR + xB - 1) / 2) * (Twobites.paperKNat (1 + Œµ) n : ‚Ñù) * Real.log (n : ‚Ñù)) +
          (((9 - 5 * (xR + xB)) / 2) * (Twobites.paperKNat (1 + Œµ) n : ‚Ñù) *
            Real.log (Real.log (n : ‚Ñù))) +
          (3 * (2 - xR - xB) * (Twobites.paperKNat (1 + Œµ) n : ‚Ñù) * Real.log (2 : ‚Ñù)) +
          ((1 - xR - xB) * (Twobites.paperKNat (1 + Œµ) n : ‚Ñù) * Real.log (1 + Œµ)) +
          (2 + xR + xB) * (Twobites.paperKNat (1 + Œµ) n : ‚Ñù)) ‚â§
        outerExp) :
    ((n.choose (Twobites.paperKNat (1 + Œµ) n) : ‚Ñï) : ‚Ñù) *
        Twobites.paperRIOuterEventMass (Twobites.paperMNat n) (C.redImage I).card
          (C.blueImage I).card (Twobites.paperKNat (1 + Œµ) n) ‚â§
      Real.exp outerExp := by
  have hxRle : xR ‚â§ 1 := C.redImage_scale_le_one_of_card_eq I hkone hI hredEq
  have hxBle : xB ‚â§ 1 := C.blueImage_scale_le_one_of_card_eq I hkone hI hblueEq
  have hmain :
      (((Twobites.paperKNat (1 + Œµ) n : ‚Ñù) *
            (1 - Real.log (1 + Œµ) +
              (Real.log (n : ‚Ñù) - Real.log (Real.log (n : ‚Ñù))) / 2)) +
          ((((xR + xB - 2) * (Twobites.paperKNat (1 + Œµ) n : ‚Ñù)) *
                (Real.log (n : ‚Ñù) - 2 * Real.log (Real.log (n : ‚Ñù)) -
                  Real.log (4 : ‚Ñù))) +
            (((2 - xR - xB) * (Twobites.paperKNat (1 + Œµ) n : ‚Ñù)) *
                (Real.log (2 : ‚Ñù) + Real.log (1 + Œµ) +
                  (Real.log (n : ‚Ñù) + Real.log (Real.log (n : ‚Ñù))) / 2)) +
            ((1 - xR) * (Twobites.paperKNat (1 + Œµ) n : ‚Ñù)) * Real.log xR +
            ((1 - xB) * (Twobites.paperKNat (1 + Œµ) n : ‚Ñù)) * Real.log xB +
            (1 + xR + xB) * (Twobites.paperKNat (1 + Œµ) n : ‚Ñù))) ‚â§
        outerExp := by
    exact (Twobites.paperRI_chooseOuterExp_le_mainRemainder hxRpos hxRle hxBpos hxBle).trans
      houterExp
  exact
    C.paper_ri_chooseOuterEventMass_le_exp_of_paperParameterLogs_of_images I hn hloglog hŒµ
      hŒµquarter hkone hsum2 hk hredM hblueM hkprod hhalf hredEq hblueEq hxRpos hxBpos
