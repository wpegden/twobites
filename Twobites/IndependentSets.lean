theorem lowerNat_mul_card_le_partWeight_of_le_xCard (C : ConstructionData n m)
    (I : Finset (Fin n)) (A : Finset (BaseVertex m)) {lower : ‚Ñï}
    (hlower : ‚àÄ x ‚àà A, lower ‚â§ C.xCard I x) :
    A.card * lower ‚â§ C.partWeight I A := by
  unfold partWeight
  calc
    A.card * lower = ‚àë _x ‚àà A, lower := by
      simp [Nat.mul_comm]
    _ ‚â§ ‚àë x ‚àà A, C.xCard I x := by
      refine Finset.sum_le_sum ?_
      intro x hx
      exact hlower x hx

theorem card_lt_of_card_lt_mul_sub_choose_mul_of_pairwise_inter_bound
    (C : ConstructionData n m) (I : Finset (Fin n)) (A : Finset (BaseVertex m))
    {lower codegreeBound witnessSize : ‚Ñï}
    (hlower : ‚àÄ x ‚àà A, lower ‚â§ C.xCard I x)
    (hinter : ‚àÄ x ‚àà A, ‚àÄ y ‚àà A, x ‚âÝ y ‚Üí (C.X I x ‚à© C.X I y).card ‚â§ codegreeBound)
    (hwitness :
      I.card < witnessSize * lower - witnessSize.choose 2 * codegreeBound) :
    A.card < witnessSize := by
  by_contra hA
  have hge : witnessSize ‚â§ A.card := Nat.not_lt.1 hA
  rcases Finset.exists_subset_card_eq hge with ‚ü®B, hBA, hBcard‚ü©
  have hLowerB : ‚àÄ x ‚àà B, lower ‚â§ C.xCard I x := by
    intro x hx
    exact hlower x (hBA hx)
  have hInterB : ‚àÄ x ‚àà B, ‚àÄ y ‚àà B, x ‚âÝ y ‚Üí (C.X I x ‚à© C.X I y).card ‚â§ codegreeBound := by
    intro x hx y hy hxy
    exact hinter x (hBA hx) y (hBA hy) hxy
  have hWeightLower : witnessSize * lower ‚â§ C.partWeight I B := by
    simpa [hBcard] using C.lowerNat_mul_card_le_partWeight_of_le_xCard I B hLowerB
  have hWeightUpper :
      C.partWeight I B ‚â§ I.card + witnessSize.choose 2 * codegreeBound := by
    simpa [hBcard] using
      C.partWeight_le_card_I_add_choose_mul_of_pairwise_inter_bound I B hInterB
  have hmul : witnessSize * lower ‚â§ I.card + witnessSize.choose 2 * codegreeBound :=
    hWeightLower.trans hWeightUpper
  have hbound : witnessSize * lower - witnessSize.choose 2 * codegreeBound ‚â§ I.card := by
    omega
  exact not_lt_of_ge hbound hwitness

theorem card_lt_of_card_lt_mul_sub_choose_mul_of_goodEventD (C : ConstructionData n m)
    {fiberBound degreeBound codegreeBound projCodegreeBound : ‚Ñï}
    (hD : GoodEventD C fiberBound degreeBound codegreeBound projCodegreeBound)
    (I : Finset (Fin n)) (A : Finset (BaseVertex m)) {lower witnessSize : ‚Ñï}
    (hlower : ‚àÄ x ‚àà A, lower ‚â§ C.xCard I x)
    (hwitness :
      I.card < witnessSize * lower - witnessSize.choose 2 * codegreeBound) :
    A.card < witnessSize := by
  apply C.card_lt_of_card_lt_mul_sub_choose_mul_of_pairwise_inter_bound I A hlower
  ¬∑ intro x hx y hy hxy
    exact C.xInter_card_le_of_goodEventD hD I hxy
  ¬∑ exact hwitness

theorem partWeight_le_card_I_add_choose_mul_of_goodEventD_of_card_le (C : ConstructionData n m)
    {fiberBound degreeBound codegreeBound projCodegreeBound : ‚Ñï}
    (hD : GoodEventD C fiberBound degreeBound codegreeBound projCodegreeBound)
    (I : Finset (Fin n)) (A : Finset (BaseVertex m)) {bound : ‚Ñï} (hA : A.card ‚â§ bound) :
    C.partWeight I A ‚â§ I.card + bound.choose 2 * codegreeBound := by
  have hchoose : A.card.choose 2 * codegreeBound ‚â§ bound.choose 2 * codegreeBound := by
    exact Nat.mul_le_mul_right _ (Nat.choose_le_choose 2 hA)
  exact (C.partWeight_le_card_I_add_choose_mul_of_goodEventD hD I A).trans
    (Nat.add_le_add_left hchoose _)

theorem LPart_card_lt_of_goodEventD_of_lt (C : ConstructionData n m)
    {fiberBound degreeBound codegreeBound projCodegreeBound : ‚Ñï}
    (hD : GoodEventD C fiberBound degreeBound codegreeBound projCodegreeBound)
    (I : Finset (Fin n)) {Œµ : ‚Ñù} {witnessSize : ‚Ñï}
    (hwitness :
      I.card < witnessSize * ‚åàTwobites.paperT2 Œµ n‚åâ‚Çä -
        witnessSize.choose 2 * codegreeBound) :
    (C.LPart I Œµ).card < witnessSize := by
  apply C.card_lt_of_card_lt_mul_sub_choose_mul_of_goodEventD hD I (C.LPart I Œµ)
  ¬∑ intro x hx
    exact (Nat.ceil_le).2 (le_of_lt ((C.mem_LPart.1 hx).1))
  ¬∑ exact hwitness

theorem LPart_card_le_of_goodEventD_of_paperWitness (C : ConstructionData n m)
    {fiberBound degreeBound codegreeBound projCodegreeBound : ‚Ñï}
    (hD : GoodEventD C fiberBound degreeBound codegreeBound projCodegreeBound)
    (I : Finset (Fin n)) {Œ∫ Œµ : ‚Ñù} {witnessSize : ‚Ñï}
    (hI : I.card ‚â§ Twobites.paperKNat Œ∫ n)
    (hwitness :
      Twobites.paperKNat Œ∫ n < witnessSize * ‚åàTwobites.paperT2 Œµ n‚åâ‚Çä -
