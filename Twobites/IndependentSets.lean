    (C.section4URedCondPairSet_image_sym2_subset_section4TRedPairSet_image_sym2
      (I := I) (A := A))]
  rw [C.section4TRedPairSet_image_sym2_card_eq, C.section4URedCondPairSet_image_sym2_card_eq]

