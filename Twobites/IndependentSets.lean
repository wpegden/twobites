theorem graphPairBernoulliMass_le_constraintMass_mul_constraintMass_of_imp
    {p : ‚Ñù} (hp0 : 0 ‚â§ p) (hp1 : p ‚â§ 1)
    (requiredR forbiddenR requiredB forbiddenB : Finset (Sym2 (Fin m)))
    (P : SimpleGraph (Fin m) √ó SimpleGraph (Fin m) ‚Üí Prop)
    [DecidablePred P]
    (hP :
      ‚àÄ x, P x ‚Üí
        requiredR ‚äÜ constructionGraphEdgeFinset x.1 ‚àß
          Disjoint forbiddenR (constructionGraphEdgeFinset x.1) ‚àß
            requiredB ‚äÜ constructionGraphEdgeFinset x.2 ‚àß
              Disjoint forbiddenB (constructionGraphEdgeFinset x.2)) :
    (‚àë x : SimpleGraph (Fin m) √ó SimpleGraph (Fin m),
        if P x then
          constructionGraphBernoulliWeight p x.1 *
            constructionGraphBernoulliWeight p x.2
        else
          0) ‚â§
      constructionGraphConstraintMass p requiredR forbiddenR *
        constructionGraphConstraintMass p requiredB forbiddenB := by
  classical
  let fR : SimpleGraph (Fin m) ‚Üí ‚Ñù := fun G =>
    if requiredR ‚äÜ constructionGraphEdgeFinset G ‚àß
          Disjoint forbiddenR (constructionGraphEdgeFinset G) then
      constructionGraphBernoulliWeight p G
    else
      0
  let fB : SimpleGraph (Fin m) ‚Üí ‚Ñù := fun G =>
    if requiredB ‚äÜ constructionGraphEdgeFinset G ‚àß
          Disjoint forbiddenB (constructionGraphEdgeFinset G) then
      constructionGraphBernoulliWeight p G
    else
      0
  have hpoint :
      ‚àÄ x : SimpleGraph (Fin m) √ó SimpleGraph (Fin m),
        (if P x then
            constructionGraphBernoulliWeight p x.1 *
              constructionGraphBernoulliWeight p x.2
          else
            0) ‚â§
          fR x.1 * fB x.2 := by
    intro x
    by_cases hPx : P x
    ¬∑ rcases hP x hPx with ‚ü®hreqR, hforbR, hreqB, hforbB‚ü©
      simp [fR, fB, hPx, hreqR, hforbR, hreqB, hforbB]
    ¬∑ have hnonnegR : 0 ‚â§ fR x.1 := by
        by_cases hcondR :
            requiredR ‚äÜ constructionGraphEdgeFinset x.1 ‚àß
              Disjoint forbiddenR (constructionGraphEdgeFinset x.1)
        ¬∑ simp [fR, hcondR, constructionGraphBernoulliWeight_nonneg hp0 hp1]
        ¬∑ simp [fR, hcondR]
      have hnonnegB : 0 ‚â§ fB x.2 := by
        by_cases hcondB :
            requiredB ‚äÜ constructionGraphEdgeFinset x.2 ‚àß
              Disjoint forbiddenB (constructionGraphEdgeFinset x.2)
        ¬∑ simp [fB, hcondB, constructionGraphBernoulliWeight_nonneg hp0 hp1]
        ¬∑ simp [fB, hcondB]
      have hnonneg : 0 ‚â§ fR x.1 * fB x.2 := mul_nonneg hnonnegR hnonnegB
      simp [hPx, hnonneg]
  have hsum :
      (‚àë x : SimpleGraph (Fin m) √ó SimpleGraph (Fin m),
          if P x then
            constructionGraphBernoulliWeight p x.1 *
              constructionGraphBernoulliWeight p x.2
          else
            0) ‚â§
        ‚àë x : SimpleGraph (Fin m) √ó SimpleGraph (Fin m), fR x.1 * fB x.2 := by
    refine Finset.sum_le_sum ?_
    intro x hx
    exact hpoint x
  have hfactor :
      (‚àë x : SimpleGraph (Fin m) √ó SimpleGraph (Fin m), fR x.1 * fB x.2) =
        constructionGraphConstraintMass p requiredR forbiddenR *
          constructionGraphConstraintMass p requiredB forbiddenB := by
    calc
      (‚àë x : SimpleGraph (Fin m) √ó SimpleGraph (Fin m), fR x.1 * fB x.2) =
          ‚àë G‚ÇÅ : SimpleGraph (Fin m),
            ‚àë G‚ÇÇ : SimpleGraph (Fin m), fR G‚ÇÅ * fB G‚ÇÇ := by
        rw [show (Finset.univ : Finset (SimpleGraph (Fin m) √ó SimpleGraph (Fin m))) =
            (Finset.univ : Finset (SimpleGraph (Fin m))) √óÀ¢
              (Finset.univ : Finset (SimpleGraph (Fin m))) by
              ext x
              simp]
        rw [Finset.sum_product]
      _ = (‚àë G‚ÇÅ : SimpleGraph (Fin m), fR G‚ÇÅ) *
            (‚àë G‚ÇÇ : SimpleGraph (Fin m), fB G‚ÇÇ) := by
        calc
          (‚àë G‚ÇÅ : SimpleGraph (Fin m), ‚àë G‚ÇÇ : SimpleGraph (Fin m), fR G‚ÇÅ * fB G‚ÇÇ) =
              ‚àë G‚ÇÅ : SimpleGraph (Fin m), fR G‚ÇÅ * ‚àë G‚ÇÇ : SimpleGraph (Fin m), fB G‚ÇÇ := by
            refine Finset.sum_congr rfl ?_
            intro G‚ÇÅ hG‚ÇÅ
            rw [‚Üê Finset.mul_sum]
          _ = (‚àë G‚ÇÅ : SimpleGraph (Fin m), fR G‚ÇÅ) *
                (‚àë G‚ÇÇ : SimpleGraph (Fin m), fB G‚ÇÇ) := by
            rw [Finset.sum_mul]
      _ = constructionGraphConstraintMass p requiredR forbiddenR *
            constructionGraphConstraintMass p requiredB forbiddenB := by
        simp [fR, fB, constructionGraphConstraintMass]
  exact hsum.trans (by rw [hfactor])

theorem graphPairBernoulliMass_le_sum_constraintMass_of_finite_imp
    {Œ± : Type*} {p : ‚Ñù} (hp0 : 0 ‚â§ p) (hp1 : p ‚â§ 1)
    (s : Finset Œ±)
    (requiredR forbiddenR requiredB forbiddenB : Œ± ‚Üí Finset (Sym2 (Fin m)))
    (P : SimpleGraph (Fin m) √ó SimpleGraph (Fin m) ‚Üí Prop)
    [DecidablePred P]
    (hP :
      ‚àÄ x, P x ‚Üí
        ‚àÉ a ‚àà s,
          requiredR a ‚äÜ constructionGraphEdgeFinset x.1 ‚àß
            Disjoint (forbiddenR a) (constructionGraphEdgeFinset x.1) ‚àß
              requiredB a ‚äÜ constructionGraphEdgeFinset x.2 ‚àß
                Disjoint (forbiddenB a) (constructionGraphEdgeFinset x.2)) :
    (‚àë x : SimpleGraph (Fin m) √ó SimpleGraph (Fin m),
        if P x then
          constructionGraphBernoulliWeight p x.1 *
            constructionGraphBernoulliWeight p x.2
        else
          0) ‚â§
      Finset.sum s (fun a =>
        constructionGraphConstraintMass p (requiredR a) (forbiddenR a) *
          constructionGraphConstraintMass p (requiredB a) (forbiddenB a)) := by
  classical
  let w : SimpleGraph (Fin m) √ó SimpleGraph (Fin m) ‚Üí ‚Ñù := fun x =>
    constructionGraphBernoulliWeight p x.1 * constructionGraphBernoulliWeight p x.2
  let Q : Œ± ‚Üí SimpleGraph (Fin m) √ó SimpleGraph (Fin m) ‚Üí Prop := fun a x =>
    requiredR a ‚äÜ constructionGraphEdgeFinset x.1 ‚àß
      Disjoint (forbiddenR a) (constructionGraphEdgeFinset x.1) ‚àß
        requiredB a ‚äÜ constructionGraphEdgeFinset x.2 ‚àß
          Disjoint (forbiddenB a) (constructionGraphEdgeFinset x.2)
  have hpoint :
      ‚àÄ x : SimpleGraph (Fin m) √ó SimpleGraph (Fin m),
        (if P x then w x else 0) ‚â§
          Finset.sum s (fun a => if Q a x then w x else 0) := by
    intro x
    by_cases hPx : P x
    ¬∑ rcases hP x hPx with ‚ü®a, ha, hQa‚ü©
      have hsingle' :
          (if Q a x then w x else 0) ‚â§ Finset.sum s (fun a => if Q a x then w x else 0) := by
        refine Finset.single_le_sum
