theorem redProjectionWeight_le_card_redProjectionUnion_add_choose_mul_of_pairwise_inter_bound
    (C : ConstructionData n m) (I : Finset (Fin n)) (A : Finset (BaseVertex m)) {D : ‚Ñï}
