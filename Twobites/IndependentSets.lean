/-- A generic finite union-bound step for functions that already carry a factor of the cardinality
of the indexing finset on the left-hand side. -/
theorem finset_sum_le_of_card_mul_le
    {Œ± : Type*} (s : Finset Œ±) {f : Œ± ‚Üí ‚Ñù} {B : ‚Ñù}
    (hB : 0 ‚â§ B)
    (hbound : ‚àÄ a ‚àà s, (s.card : ‚Ñù) * f a ‚â§ B) :
    s.sum f ‚â§ B := by
  by_cases hs0 : s.card = 0
  ¬∑ have hs : s = ‚àÖ := Finset.card_eq_zero.mp hs0
    simp [hs, hB]
  ¬∑ have hsposNat : 0 < s.card := Nat.pos_iff_ne_zero.mpr hs0
    have hspos : 0 < (s.card : ‚Ñù) := by exact_mod_cast hsposNat
    have hpoint : ‚àÄ a ‚àà s, f a ‚â§ B / (s.card : ‚Ñù) := by
      intro a ha
      have hmul : f a * (s.card : ‚Ñù) ‚â§ B := by
        simpa [mul_comm] using hbound a ha
      exact (le_div_iff‚ÇÄ hspos).2 hmul
    calc
      s.sum f ‚â§ s.sum fun _ => B / (s.card : ‚Ñù) := Finset.sum_le_sum hpoint
      _ = (s.card : ‚Ñù) * (B / (s.card : ‚Ñù)) := by rw [Finset.sum_const, nsmul_eq_mul]
      _ = B := by field_simp [hspos.ne']

/-- The finite union-bound shell over all `k`-subsets of `Fin n`, matching the paper's final
sum over independent-set candidates once a uniform per-set RI estimate is available. -/
theorem sum_powersetCard_le_of_choose_mul_le
    {k : ‚Ñï} {f : Finset (Fin n) ‚Üí ‚Ñù} {B : ‚Ñù}
    (hB : 0 ‚â§ B)
    (hbound :
      ‚àÄ I ‚àà (Finset.univ : Finset (Fin n)).powersetCard k,
        ((n.choose k : ‚Ñï) : ‚Ñù) * f I ‚â§ B) :
    (((Finset.univ : Finset (Fin n)).powersetCard k).sum f) ‚â§ B := by
  let s : Finset (Finset (Fin n)) := (Finset.univ : Finset (Fin n)).powersetCard k
  have hsCardNat : s.card = n.choose k := by
    simp [s]
  refine finset_sum_le_of_card_mul_le s hB ?_
  intro I hI
  have h := hbound I (by simpa [s] using hI)
  simpa [s, hsCardNat] using h

/-- A fixed vertex set survives the final deletion step as an independent set. -/
def SurvivesAsIndependent (C : ConstructionData n m) (I : Finset (Fin n)) : Prop :=
  ‚àÄ {v w : Fin n}, v ‚àà I ‚Üí w ‚àà I ‚Üí v ‚âÝ w ‚Üí ¬¨ C.finalGraph.Adj v w

/-- The finite event that a fixed `I ‚äÜ [n]` survives as an independent set in the final graph. -/
noncomputable def survivingIndepSetEventSet (n m : ‚Ñï) (I : Finset (Fin n)) :
    Finset (ConstructionData n m) :=
  by
    classical
    exact (ConstructionData.sampleSpace n m).filter fun C => C.SurvivesAsIndependent I

@[simp] theorem mem_survivingIndepSetEventSet_iff
    {n m : ‚Ñï} {I : Finset (Fin n)} {C : ConstructionData n m} :
    C ‚àà survivingIndepSetEventSet n m I ‚Üî C.SurvivesAsIndependent I := by
  classical
  simp [survivingIndepSetEventSet, ConstructionData.sampleSpace, SurvivesAsIndependent]

/-- The finite event that a fixed `I ‚äÜ [n]` survives as an independent set while the deterministic
good event `ùíü` also holds. This is the exact weighted event to which the finished RI bound will
eventually be applied. -/
noncomputable def goodSurvivingIndepSetEventSet
    (n m fiberBound degreeBound codegreeBound projCodegreeBound : ‚Ñï) (I : Finset (Fin n)) :
    Finset (ConstructionData n m) :=
  by
    classical
    exact
      (goodEventDSet n m fiberBound degreeBound codegreeBound projCodegreeBound).filter
        fun C => C.SurvivesAsIndependent I

@[simp] theorem mem_goodSurvivingIndepSetEventSet_iff
    {n m fiberBound degreeBound codegreeBound projCodegreeBound : ‚Ñï}
    {I : Finset (Fin n)} {C : ConstructionData n m} :
    C ‚àà goodSurvivingIndepSetEventSet
        n m fiberBound degreeBound codegreeBound projCodegreeBound I ‚Üî
      GoodEventD C fiberBound degreeBound codegreeBound projCodegreeBound ‚àß
        C.SurvivesAsIndependent I := by
  classical
  simp [goodSurvivingIndepSetEventSet, SurvivesAsIndependent]

