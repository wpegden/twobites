    _ ‚â§ Œµ * ((a : ‚Ñù) * ((a : ‚Ñù) - 1) / 2) := hfinal
    _ = Œµ * (((a.choose 2 : ‚Ñï) : ‚Ñù)) := by rw [Nat.cast_choose_two]

theorem cast_mul_add_choose_two_le_eps_mul_choose_two_cap_add_choose_two_sub_of_le_of_three_mul_le
    {a b cap : ‚Ñï} {Œµ : ‚Ñù} (hŒµ : 0 ‚â§ Œµ) (hb : b ‚â§ a - cap)
    (hsmall : (3 : ‚Ñù) * (b : ‚Ñù) ‚â§ Œµ * (((a - cap : ‚Ñï) : ‚Ñù) - 1)) :
    ((a - cap : ‚Ñï) : ‚Ñù) * b + ((b.choose 2 : ‚Ñï) : ‚Ñù) ‚â§
      Œµ * (((cap.choose 2 + (a - cap).choose 2 : ‚Ñï) : ‚Ñù)) := by
  have hbase :
      (((a - cap : ‚Ñï) : ‚Ñù) * b + ((b.choose 2 : ‚Ñï) : ‚Ñù)) ‚â§
        Œµ * ((((a - cap).choose 2 : ‚Ñï) : ‚Ñù)) := by
    exact cast_mul_add_choose_two_le_eps_mul_choose_two_of_le_of_three_mul_le hb hsmall
  have hmono :
      Œµ * ((((a - cap).choose 2 : ‚Ñï) : ‚Ñù)) ‚â§
        Œµ * (((cap.choose 2 + (a - cap).choose 2 : ‚Ñï) : ‚Ñù)) := by
    have hnat : (a - cap).choose 2 ‚â§ cap.choose 2 + (a - cap).choose 2 := by
      exact Nat.le_add_left _ _
    have hcast :
        ((((a - cap).choose 2 : ‚Ñï) : ‚Ñù)) ‚â§
          (((cap.choose 2 + (a - cap).choose 2 : ‚Ñï) : ‚Ñù)) := by
      exact_mod_cast hnat
    exact mul_le_mul_of_nonneg_left hcast hŒµ
  exact hbase.trans hmono

theorem real_mul_add_sq_half_le_eps_mul_choose_two_of_le_of_three_mul_le
    {a : ‚Ñï} {W Œµ : ‚Ñù} (hW : 0 ‚â§ W) (hbound : W ‚â§ (a : ‚Ñù))
