theorem redProjectionPairCount_le_min_choose_of_weight_bounds (C : ConstructionData n m)
    (I : Finset (Fin n)) (A : Finset (BaseVertex m)) {cap W : ‚Ñï}
    (hcap : ‚àÄ x ‚àà A, (C.redProjectionImage I x).card ‚â§ cap)
    (hcapWeight : cap ‚â§ C.redProjectionWeight I A) (hweight : C.redProjectionWeight I A ‚â§ W) :
    C.redProjectionPairCount I A ‚â§ min (W.choose 2) (cap.choose 2 + (W - cap).choose 2) := by
