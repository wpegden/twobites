theorem paperSection4OpenPairTarget_lower_bound_of_targetBounds
    (C : ConstructionData n m) (I : Finset (Fin n)) {Œ∫ : ‚Ñù} {cap blueBound redBound : ‚Ñï}
    (hblue : C.paperHugeBlueCrossTargetNat I Œ∫ cap ‚â§ blueBound)
    (hred : C.paperHugeRedCrossTargetNat I Œ∫ cap ‚â§ redBound) :
    (((C.redImage I).card.choose 2 : ‚Ñï) : ‚Ñù) + (((C.blueImage I).card.choose 2 : ‚Ñï) : ‚Ñù) -
        (blueBound : ‚Ñù) - (redBound : ‚Ñù) ‚â§
      C.paperSection4OpenPairTarget I Œ∫ cap := by
  let totalChoose := (C.redImage I).card.choose 2 + (C.blueImage I).card.choose 2
  let totalTarget := C.paperHugeBlueCrossTargetNat I Œ∫ cap + C.paperHugeRedCrossTargetNat I Œ∫ cap
  let totalBound := blueBound + redBound
  have htargetLeBound : totalTarget ‚â§ totalBound := by
    dsimp [totalTarget, totalBound]
    exact Nat.add_le_add hblue hred
  have hsplit :
      (((C.redImage I).card.choose 2 : ‚Ñï) : ‚Ñù) + (((C.blueImage I).card.choose 2 : ‚Ñï) : ‚Ñù) -
          (blueBound : ‚Ñù) - (redBound : ‚Ñù) =
        (totalChoose : ‚Ñù) - (totalBound : ‚Ñù) := by
    dsimp [totalChoose, totalBound]
    rw [Nat.cast_add, Nat.cast_add]
    ring
  by_cases hle : totalTarget ‚â§ totalChoose
  ¬∑ have hle' :
        C.paperHugeBlueCrossTargetNat I Œ∫ cap + C.paperHugeRedCrossTargetNat I Œ∫ cap ‚â§
          (C.redImage I).card.choose 2 + (C.blueImage I).card.choose 2 := by
      simpa [totalChoose, totalTarget] using hle
    have htarget :
        C.paperSection4OpenPairTarget I Œ∫ cap = (totalChoose : ‚Ñù) - (totalTarget : ‚Ñù) := by
      unfold paperSection4OpenPairTarget paperSection4OpenPairTargetNat totalChoose totalTarget
      rw [Nat.sub_sub, Nat.cast_sub hle', Nat.cast_add]
    have htargetLeBoundR : (totalTarget : ‚Ñù) ‚â§ (totalBound : ‚Ñù) := by
      exact_mod_cast htargetLeBound
    rw [hsplit]
    calc
      (totalChoose : ‚Ñù) - (totalBound : ‚Ñù) ‚â§ (totalChoose : ‚Ñù) - (totalTarget : ‚Ñù) := by
        linarith
      _ = C.paperSection4OpenPairTarget I Œ∫ cap := htarget.symm
  ¬∑ have hzero : C.paperSection4OpenPairTarget I Œ∫ cap = 0 := by
      have hlt : totalChoose < totalTarget := Nat.lt_of_not_ge hle
      have hle' :
          (C.redImage I).card.choose 2 + (C.blueImage I).card.choose 2 ‚â§
            C.paperHugeBlueCrossTargetNat I Œ∫ cap + C.paperHugeRedCrossTargetNat I Œ∫ cap := by
        simpa [totalChoose, totalTarget] using hlt.le
      unfold paperSection4OpenPairTarget paperSection4OpenPairTargetNat
      rw [Nat.sub_sub, Nat.sub_eq_zero_of_le hle', Nat.cast_zero]
    have hnonpos :
        (((C.redImage I).card.choose 2 : ‚Ñï) : ‚Ñù) + (((C.blueImage I).card.choose 2 : ‚Ñï) : ‚Ñù) -
            (blueBound : ‚Ñù) - (redBound : ‚Ñù) ‚â§
          0 := by
      have hlt : totalChoose < totalTarget := Nat.lt_of_not_ge hle
      have hlt' : (totalChoose : ‚Ñù) < (totalBound : ‚Ñù) := by
        exact_mod_cast (lt_of_lt_of_le hlt htargetLeBound)
      rw [hsplit]
      linarith
    nlinarith [hzero]

