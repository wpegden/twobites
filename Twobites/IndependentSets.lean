/-- The combined manuscript-scale deterministic loss term that remains to be dominated by the
Section 4 target in `lem:RISI`. -/
def paperRISILossNat (Œ∫ Œµ1 : ‚Ñù) (n : ‚Ñï) : ‚Ñï :=
  ‚åà9 * (Œµ1 * Twobites.paperK Œ∫ n ^ 2)‚åâ‚Çä + ‚åà10 * (Œµ1 * Twobites.paperK Œ∫ n ^ 2)‚åâ‚Çä

theorem paperRISILossNat_le_natCeil_nineteen_mul_eps_mul_paperKSq_add_one
    {Œ∫ Œµ1 : ‚Ñù} (n : ‚Ñï) (hŒµ1 : 0 ‚â§ Œµ1) :
    paperRISILossNat Œ∫ Œµ1 n ‚â§ ‚åà19 * (Œµ1 * Twobites.paperK Œ∫ n ^ 2)‚åâ‚Çä + 1 := by
  have h9 :
      0 ‚â§ 9 * (Œµ1 * Twobites.paperK Œ∫ n ^ 2) := by
    nlinarith [sq_nonneg (Twobites.paperK Œ∫ n)]
  have h10 :
      0 ‚â§ 10 * (Œµ1 * Twobites.paperK Œ∫ n ^ 2) := by
    nlinarith [sq_nonneg (Twobites.paperK Œ∫ n)]
  calc
    paperRISILossNat Œ∫ Œµ1 n =
        ‚åà9 * (Œµ1 * Twobites.paperK Œ∫ n ^ 2)‚åâ‚Çä +
          ‚åà10 * (Œµ1 * Twobites.paperK Œ∫ n ^ 2)‚åâ‚Çä := rfl
    _ ‚â§ ‚åà9 * (Œµ1 * Twobites.paperK Œ∫ n ^ 2) +
          10 * (Œµ1 * Twobites.paperK Œ∫ n ^ 2)‚åâ‚Çä + 1 := by
      exact Twobites.natCeil_add_natCeil_le_natCeil_add_one h9 h10
    _ = ‚åà19 * (Œµ1 * Twobites.paperK Œ∫ n ^ 2)‚åâ‚Çä + 1 := by ring_nf

