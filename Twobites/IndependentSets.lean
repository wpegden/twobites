    exact sum_powersetCard_le_of_choose_mul_le hB hbound
  exact
    (constructionEventMass_goodSurvivingIndepSetCardBadSet_le_sum
      (w := w) (n := n) (m := m) (fiberBound := fiberBound) (degreeBound := degreeBound)
      (codegreeBound := codegreeBound) (projCodegreeBound := projCodegreeBound) (k := k)
      hwt).trans hsum

/-- The paper's terminal bad-event condition at fixed set size `k`: no `k`-subset of the final
graph survives as an independent set. This is the deterministic hypothesis that the still-missing
global probability layer should eventually produce. -/
def NoSurvivingIndepSetCard (C : ConstructionData n m) (k : ‚Ñï) : Prop :=
  ‚àÄ I ‚àà (Finset.univ : Finset (Fin n)).powersetCard k,
    ¬¨ C.SurvivesAsIndependent I

@[simp] theorem not_mem_survivingIndepSetCardBadSet_iff
    {n m k : ‚Ñï} {C : ConstructionData n m} :
    C ‚àâ survivingIndepSetCardBadSet n m k ‚Üî C.NoSurvivingIndepSetCard k := by
  classical
  simp [NoSurvivingIndepSetCard]

theorem exists_goodEventD_with_noSurvivingIndepSetCard_of_mass_lt
    {w : ConstructionData n m ‚Üí ‚Ñù}
    {fiberBound degreeBound codegreeBound projCodegreeBound k : ‚Ñï}
    (hwt : ‚àÄ C, 0 ‚â§ w C)
    (hmass :
      constructionEventMass w
          (goodSurvivingIndepSetCardBadSet n m fiberBound degreeBound codegreeBound
            projCodegreeBound k) <
        constructionEventMass w
          (goodEventDSet n m fiberBound degreeBound codegreeBound projCodegreeBound)) :
    ‚àÉ C ‚àà goodEventDSet n m fiberBound degreeBound codegreeBound projCodegreeBound,
      C.NoSurvivingIndepSetCard k := by
  classical
  by_contra hno
  push_neg at hno
  have hsubset :
      goodEventDSet n m fiberBound degreeBound codegreeBound projCodegreeBound ‚äÜ
        goodSurvivingIndepSetCardBadSet n m fiberBound degreeBound codegreeBound
          projCodegreeBound k := by
    intro C hC
    have hbad : ¬¨ C.NoSurvivingIndepSetCard k := hno C hC
    have hmemBad : C ‚àà survivingIndepSetCardBadSet n m k := by
      by_contra hnotmem
      exact hbad ((not_mem_survivingIndepSetCardBadSet_iff).1 hnotmem)
    rcases (mem_survivingIndepSetCardBadSet_iff).1 hmemBad with ‚ü®I, hI, hsurv‚ü©
    rw [mem_goodSurvivingIndepSetCardBadSet_iff]
    exact ‚ü®(mem_goodEventDSet_iff.mp hC), I, hI, hsurv‚ü©
  have hmono :
      constructionEventMass w
          (goodEventDSet n m fiberBound degreeBound codegreeBound projCodegreeBound) ‚â§
        constructionEventMass w
          (goodSurvivingIndepSetCardBadSet n m fiberBound degreeBound codegreeBound
            projCodegreeBound k) :=
    constructionEventMass_mono hsubset hwt
  exact not_le_of_gt hmass hmono

theorem exists_goodEventD_with_noSurvivingIndepSetCard_of_choose_mul_le_lt_goodMass
    {w : ConstructionData n m ‚Üí ‚Ñù}
    {fiberBound degreeBound codegreeBound projCodegreeBound k : ‚Ñï} {B : ‚Ñù}
    (hwt : ‚àÄ C, 0 ‚â§ w C) (hB : 0 ‚â§ B)
    (hbound :
      ‚àÄ I ‚àà (Finset.univ : Finset (Fin n)).powersetCard k,
        ((n.choose k : ‚Ñï) : ‚Ñù) *
            constructionEventMass w
              (goodSurvivingIndepSetEventSet n m fiberBound degreeBound codegreeBound
                projCodegreeBound I) ‚â§
          B)
    (hgood :
      B <
        constructionEventMass w
          (goodEventDSet n m fiberBound degreeBound codegreeBound projCodegreeBound)) :
    ‚àÉ C ‚àà goodEventDSet n m fiberBound degreeBound codegreeBound projCodegreeBound,
      C.NoSurvivingIndepSetCard k := by
  have hbad :
      constructionEventMass w
          (goodSurvivingIndepSetCardBadSet n m fiberBound degreeBound codegreeBound
            projCodegreeBound k) ‚â§
        B :=
    constructionEventMass_goodSurvivingIndepSetCardBadSet_le_of_choose_mul_le
      (n := n) (m := m) (fiberBound := fiberBound) (degreeBound := degreeBound)
      (codegreeBound := codegreeBound) (projCodegreeBound := projCodegreeBound) (k := k)
      hB hwt hbound
  apply exists_goodEventD_with_noSurvivingIndepSetCard_of_mass_lt hwt
  exact lt_of_le_of_lt hbad hgood

theorem exists_goodEventD_with_noSurvivingIndepSetCard_of_paperChooseMulLe_lt_goodMass
    {Œ≤ : ‚Ñù}
    {fiberBound degreeBound codegreeBound projCodegreeBound k : ‚Ñï} {B : ‚Ñù}
    (hp0 : 0 ‚â§ Twobites.paperP Œ≤ n) (hp1 : Twobites.paperP Œ≤ n ‚â§ 1) (hB : 0 ‚â§ B)
    (hbound :
