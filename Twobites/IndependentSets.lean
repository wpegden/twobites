    Œµ1 * C.paperHugeRedCrossRightTarget I Œ∫ cap

/-- The current natural-number upper bound for the `H_I ‚à© V_B` cross-projection term, before the
final paper asymptotic simplifications are applied. -/
def paperHugeRedCrossConcreteBoundNat (C : ConstructionData n m) (I : Finset (Fin n)) (Œ∫ : ‚Ñù)
    (witnessSize degreeBound projCodegreeBound cap : ‚Ñï) : ‚Ñï :=
  min
    ((Twobites.paperKNat Œ∫ n - (C.blueImage I).card +
      C.paperHugeRedCrossErrorNat I witnessSize degreeBound projCodegreeBound).choose 2)
    (cap.choose 2 +
      ((Twobites.paperKNat Œ∫ n - (C.blueImage I).card +
        C.paperHugeRedCrossErrorNat I witnessSize degreeBound projCodegreeBound) - cap).choose 2)

/-- The paper's target natural-number expression for the `H_I ‚à© V_B` cross-projection term. -/
def paperHugeRedCrossTargetNat (C : ConstructionData n m) (I : Finset (Fin n)) (Œ∫ : ‚Ñù)
    (cap : ‚Ñï) : ‚Ñï :=
  min
    ((Twobites.paperKNat Œ∫ n - (C.blueImage I).card).choose 2)
    (C.paperHugeRedCrossRightTargetNat I Œ∫ cap)

/-- The paper's Section 4 target
`f(‚Ñì_R, ‚Ñì_B) = choose(‚Ñì_R) + choose(‚Ñì_B) - target_R - target_B`,
expressed in the repo's natural-number bookkeeping with `‚Ñì_R = |œÄ_R(I)|`,
`‚Ñì_B = |œÄ_B(I)|`, and a generic huge-case cap parameter. -/
def paperSection4OpenPairTargetNat (C : ConstructionData n m) (I : Finset (Fin n)) (Œ∫ : ‚Ñù)
    (cap : ‚Ñï) : ‚Ñï :=
  (C.redImage I).card.choose 2 + (C.blueImage I).card.choose 2 -
    C.paperHugeBlueCrossTargetNat I Œ∫ cap - C.paperHugeRedCrossTargetNat I Œ∫ cap

/-- The real-valued coercion of the paper's Section 4 target `f(‚Ñì_R,‚Ñì_B)`. -/
