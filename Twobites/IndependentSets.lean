theorem one_sub_pow_le_one_sub_pow_of_le {p : ‚Ñù}
    (hp0 : 0 ‚â§ p) (hp1 : p ‚â§ 1) {m n : ‚Ñï} (hmn : m ‚â§ n) :
    (1 - p) ^ n ‚â§ (1 - p) ^ m := by
  refine pow_le_pow_of_le_one ?_ ?_ hmn
  ¬∑ linarith
  ¬∑ linarith

theorem pow_le_pow_of_nonneg_le_one_nat {p : ‚Ñù}
    (hp0 : 0 ‚â§ p) (hp1 : p ‚â§ 1) {m n : ‚Ñï} (hmn : m ‚â§ n) :
    p ^ n ‚â§ p ^ m := by
  induction hmn with
  | refl =>
      rfl
  | @step n hmn ih =>
      calc
        p ^ (n + 1) = p ^ n * p := by rw [pow_succ]
        _ ‚â§ p ^ n * 1 := by
          exact mul_le_mul_of_nonneg_left hp1 (pow_nonneg hp0 _)
        _ = p ^ n := by ring
        _ ‚â§ p ^ m := ih

theorem section4ChoiceMass_le_of_choiceBound_of_le_remaining
    (C : ConstructionData n m) {I : Finset (Fin n)} {A : Finset (BaseVertex m)}
    {p : ‚Ñù} {uR uB remaining R B L : ‚Ñï}
    (hchoice : (C.section4UChoiceSet I A uR uB).card ‚â§ R.choose uR * B.choose uB)
    (hremaining : L ‚â§ remaining) (hp0 : 0 ‚â§ p) (hp1 : p ‚â§ 1) :
    C.section4ChoiceMass I A p uR uB remaining ‚â§
      ((((R.choose uR : ‚Ñï) : ‚Ñù) * p ^ uR) *
          (((B.choose uB : ‚Ñï) : ‚Ñù) * p ^ uB)) *
        (1 - p) ^ L := by
  have hchoice' :
      ((C.section4UChoiceSet I A uR uB).card : ‚Ñù) ‚â§
        (((R.choose uR * B.choose uB : ‚Ñï) : ‚Ñù)) := by
    exact_mod_cast hchoice
  have hpow : 0 ‚â§ p ^ (uR + uB) := pow_nonneg hp0 _
  have hone : 0 ‚â§ (1 - p) ^ remaining := by
    have hsub : 0 ‚â§ 1 - p := by linarith
    exact pow_nonneg hsub _
  have hfirst :
      ((C.section4UChoiceSet I A uR uB).card : ‚Ñù) * p ^ (uR + uB) ‚â§
        (((R.choose uR * B.choose uB : ‚Ñï) : ‚Ñù)) * p ^ (uR + uB) := by
    exact mul_le_mul_of_nonneg_right hchoice' hpow
  have hsecond :
      (1 - p) ^ remaining ‚â§ (1 - p) ^ L :=
    one_sub_pow_le_one_sub_pow_of_le hp0 hp1 hremaining
  have hbase :
      (((C.section4UChoiceSet I A uR uB).card : ‚Ñù) * p ^ (uR + uB)) * (1 - p) ^ remaining ‚â§
        ((((R.choose uR * B.choose uB : ‚Ñï) : ‚Ñù)) * p ^ (uR + uB)) * (1 - p) ^ L := by
    exact mul_le_mul hfirst hsecond hone (by positivity)
  calc
    C.section4ChoiceMass I A p uR uB remaining =
        (((C.section4UChoiceSet I A uR uB).card : ‚Ñù) * p ^ (uR + uB)) *
          (1 - p) ^ remaining := by
      simp [section4ChoiceMass, section4BernoulliMass, mul_assoc]
    _ ‚â§ ((((R.choose uR * B.choose uB : ‚Ñï) : ‚Ñù)) * p ^ (uR + uB)) *
          (1 - p) ^ L := hbase
    _ =
        ((((R.choose uR : ‚Ñï) : ‚Ñù) * p ^ uR) *
            (((B.choose uB : ‚Ñï) : ‚Ñù) * p ^ uB)) *
          (1 - p) ^ L := by
      rw [pow_add, Nat.cast_mul]
      ring

theorem section4BernoulliMass_eq_of_mem_section4UChoiceSet
    (C : ConstructionData n m) {I : Finset (Fin n)} {A : Finset (BaseVertex m)}
    {p : ‚Ñù} {uR uB remaining : ‚Ñï}
    {outcome : Finset (Sym2 (Fin m)) √ó Finset (Sym2 (Fin m))}
    (houtcome : outcome ‚àà C.section4UChoiceSet I A uR uB) :
    section4BernoulliMass p outcome.1.card outcome.2.card remaining =
      section4BernoulliMass p uR uB remaining := by
  rcases Finset.mem_product.1 houtcome with ‚ü®hR, hB‚ü©
  have hRc : outcome.1.card = uR := (Finset.mem_powersetCard.1 hR).2
  have hBc : outcome.2.card = uB := (Finset.mem_powersetCard.1 hB).2
  simp [section4BernoulliMass, hRc, hBc]

theorem section4ChoiceEventMass_eq_section4ChoiceMass
    (C : ConstructionData n m) (I : Finset (Fin n)) (A : Finset (BaseVertex m))
    (p : ‚Ñù) (uR uB remaining : ‚Ñï) :
    C.section4ChoiceEventMass I A p uR uB remaining =
      C.section4ChoiceMass I A p uR uB remaining := by
  classical
  unfold section4ChoiceEventMass
  calc
    Finset.sum (C.section4UChoiceSet I A uR uB) (fun outcome =>
        section4BernoulliMass p outcome.1.card outcome.2.card remaining) =
      Finset.sum (C.section4UChoiceSet I A uR uB) (fun _outcome =>
        section4BernoulliMass p uR uB remaining) := by
        refine Finset.sum_congr rfl ?_
        intro outcome houtcome
        exact C.section4BernoulliMass_eq_of_mem_section4UChoiceSet houtcome
    _ = ((C.section4UChoiceSet I A uR uB).card : ‚Ñù) *
          section4BernoulliMass p uR uB remaining := by
        rw [Finset.sum_const, nsmul_eq_mul]
    _ = C.section4ChoiceMass I A p uR uB remaining := by
        simp [section4ChoiceMass]

theorem section4ChoiceEventMass_le_projectionChoiceMass
    (C : ConstructionData n m) {I : Finset (Fin n)} {A : Finset (BaseVertex m)}
    {p : ‚Ñù} {uR uB remaining : ‚Ñï} (hp0 : 0 ‚â§ p) (hp1 : p ‚â§ 1) :
    C.section4ChoiceEventMass I A p uR uB remaining ‚â§
      ((((C.redProjectionPairCount I
              ((Finset.univ.filter fun b : Fin m => Sum.inr b ‚àâ A).image Sum.inr)).choose uR :
            ‚Ñù) *
          p ^ uR) *
        (((C.blueProjectionPairCount I
              ((Finset.univ.filter fun r : Fin m => Sum.inl r ‚àâ A).image Sum.inl)).choose uB :
            ‚Ñù) *
          p ^ uB)) *
        (1 - p) ^ remaining := by
  rw [C.section4ChoiceEventMass_eq_section4ChoiceMass]
  exact
    C.section4ChoiceMass_le_of_choiceBound_of_le_remaining
      (C.section4UChoiceSet_card_le_choose_mul_choose (I := I) (A := A)) (le_rfl) hp0 hp1

theorem section4ChoiceEventMassSum_le_projectionChoiceMassSum
    (C : ConstructionData n m) {I : Finset (Fin n)} {A : Finset (BaseVertex m)}
    {p : ‚Ñù} {remaining : ‚Ñï} (hp0 : 0 ‚â§ p) (hp1 : p ‚â§ 1) :
    C.section4ChoiceEventMassSum I A p remaining
        (C.redProjectionPairCount I
          ((Finset.univ.filter fun b : Fin m => Sum.inr b ‚àâ A).image Sum.inr))
        (C.blueProjectionPairCount I
          ((Finset.univ.filter fun r : Fin m => Sum.inl r ‚àâ A).image Sum.inl)) ‚â§
      section4ProjectionChoiceMassSum p remaining
        (C.redProjectionPairCount I
          ((Finset.univ.filter fun b : Fin m => Sum.inr b ‚àâ A).image Sum.inr))
        (C.blueProjectionPairCount I
          ((Finset.univ.filter fun r : Fin m => Sum.inl r ‚àâ A).image Sum.inl)) := by
  unfold section4ChoiceEventMassSum section4ProjectionChoiceMassSum
  exact Finset.sum_le_sum fun uv : ‚Ñï √ó ‚Ñï => fun _ =>
    C.section4ChoiceEventMass_le_projectionChoiceMass
      (I := I) (A := A) (remaining := remaining) (uR := uv.1) (uB := uv.2) hp0 hp1

theorem section4ProjectionChoiceMassSum_eq_closedForm
    (p : ‚Ñù) (remaining uRMax uBMax : ‚Ñï) :
    section4ProjectionChoiceMassSum p remaining uRMax uBMax =
      ((1 + p) ^ uRMax) * ((1 + p) ^ uBMax) * (1 - p) ^ remaining := by
  let f : ‚Ñï ‚Üí ‚Ñù := fun uR => ((uRMax.choose uR : ‚Ñï) : ‚Ñù) * p ^ uR
  let g : ‚Ñï ‚Üí ‚Ñù := fun uB => ((uBMax.choose uB : ‚Ñï) : ‚Ñù) * p ^ uB
  let c : ‚Ñù := (1 - p) ^ remaining
  have hR :
      Finset.sum (Finset.range (uRMax + 1)) f = (1 + p) ^ uRMax := by
    calc
      Finset.sum (Finset.range (uRMax + 1)) f =
          Finset.sum (Finset.range (uRMax + 1))
            (fun uR => p ^ uR * 1 ^ (uRMax - uR) * ((uRMax.choose uR : ‚Ñï) : ‚Ñù)) := by
          refine Finset.sum_congr rfl ?_
          intro uR huR
          simp [f]
          ring
      _ = (p + 1) ^ uRMax := by
          simpa [add_comm] using (add_pow p (1 : ‚Ñù) uRMax).symm
      _ = (1 + p) ^ uRMax := by rw [add_comm]
  have hB :
      Finset.sum (Finset.range (uBMax + 1)) g = (1 + p) ^ uBMax := by
    calc
      Finset.sum (Finset.range (uBMax + 1)) g =
          Finset.sum (Finset.range (uBMax + 1))
            (fun uB => p ^ uB * 1 ^ (uBMax - uB) * ((uBMax.choose uB : ‚Ñï) : ‚Ñù)) := by
          refine Finset.sum_congr rfl ?_
          intro uB huB
          simp [g]
          ring
      _ = (p + 1) ^ uBMax := by
          simpa [add_comm] using (add_pow p (1 : ‚Ñù) uBMax).symm
      _ = (1 + p) ^ uBMax := by rw [add_comm]
  calc
    section4ProjectionChoiceMassSum p remaining uRMax uBMax =
        Finset.sum (Finset.range (uRMax + 1))
          (fun uR =>
            Finset.sum (Finset.range (uBMax + 1)) fun uB => (f uR * g uB) * c) := by
      unfold section4ProjectionChoiceMassSum section4CountIndexSet
      rw [Finset.sum_product]
    _ = (Finset.sum (Finset.range (uRMax + 1)) f) *
          (Finset.sum (Finset.range (uBMax + 1)) g) * c := by
      calc
        Finset.sum (Finset.range (uRMax + 1))
            (fun uR =>
              Finset.sum (Finset.range (uBMax + 1)) fun uB => (f uR * g uB) * c) =
            Finset.sum (Finset.range (uRMax + 1))
              (fun uR => f uR * Finset.sum (Finset.range (uBMax + 1)) (fun uB => g uB * c)) := by
          refine Finset.sum_congr rfl ?_
          intro uR huR
          calc
            Finset.sum (Finset.range (uBMax + 1)) (fun uB => (f uR * g uB) * c) =
                Finset.sum (Finset.range (uBMax + 1)) (fun uB => f uR * (g uB * c)) := by
              refine Finset.sum_congr rfl ?_
              intro uB huB
              ring
            _ = f uR * Finset.sum (Finset.range (uBMax + 1)) (fun uB => g uB * c) := by
              rw [Finset.mul_sum]
        _ = Finset.sum (Finset.range (uRMax + 1))
              (fun uR => f uR * (Finset.sum (Finset.range (uBMax + 1)) g * c)) := by
          refine Finset.sum_congr rfl ?_
          intro uR huR
          rw [Finset.sum_mul]
        _ = Finset.sum (Finset.range (uRMax + 1)) f *
              (Finset.sum (Finset.range (uBMax + 1)) g * c) := by
          rw [‚Üê Finset.sum_mul]
        _ = Finset.sum (Finset.range (uRMax + 1)) f *
              Finset.sum (Finset.range (uBMax + 1)) g * c := by
          ring
    _ = ((1 + p) ^ uRMax) * ((1 + p) ^ uBMax) * (1 - p) ^ remaining := by
      simp [hR, hB, c]

theorem section4ProjectionChoiceMassSum_mono
    {p : ‚Ñù} (hp0 : 0 ‚â§ p) (hp1 : p ‚â§ 1)
    {remaining‚ÇÅ remaining‚ÇÇ uRMax‚ÇÅ uRMax‚ÇÇ uBMax‚ÇÅ uBMax‚ÇÇ : ‚Ñï}
    (hremaining : remaining‚ÇÇ ‚â§ remaining‚ÇÅ)
    (hUR : uRMax‚ÇÅ ‚â§ uRMax‚ÇÇ)
    (hUB : uBMax‚ÇÅ ‚â§ uBMax‚ÇÇ) :
    section4ProjectionChoiceMassSum p remaining‚ÇÅ uRMax‚ÇÅ uBMax‚ÇÅ ‚â§
      section4ProjectionChoiceMassSum p remaining‚ÇÇ uRMax‚ÇÇ uBMax‚ÇÇ := by
  have hpAdd0 : 0 ‚â§ 1 + p := by linarith
  have hpAdd1 : 1 ‚â§ 1 + p := by linarith
  have hq0 : 0 ‚â§ 1 - p := by linarith
  have hq1 : 1 - p ‚â§ 1 := by linarith
  have hR : (1 + p) ^ uRMax‚ÇÅ ‚â§ (1 + p) ^ uRMax‚ÇÇ := by
    rcases Nat.exists_eq_add_of_le hUR with ‚ü®k, rfl‚ü©
    rw [pow_add]
    have hpow0 : 0 ‚â§ (1 + p) ^ uRMax‚ÇÅ := pow_nonneg hpAdd0 _
    have hpow1 : 1 ‚â§ (1 + p) ^ k := one_le_pow‚ÇÄ hpAdd1
    nlinarith
  have hB : (1 + p) ^ uBMax‚ÇÅ ‚â§ (1 + p) ^ uBMax‚ÇÇ := by
    rcases Nat.exists_eq_add_of_le hUB with ‚ü®k, rfl‚ü©
    rw [pow_add]
    have hpow0 : 0 ‚â§ (1 + p) ^ uBMax‚ÇÅ := pow_nonneg hpAdd0 _
    have hpow1 : 1 ‚â§ (1 + p) ^ k := one_le_pow‚ÇÄ hpAdd1
    nlinarith
  have hRem : (1 - p) ^ remaining‚ÇÅ ‚â§ (1 - p) ^ remaining‚ÇÇ := by
    exact pow_le_pow_of_nonneg_le_one_nat hq0 hq1 hremaining
  rw [section4ProjectionChoiceMassSum_eq_closedForm, section4ProjectionChoiceMassSum_eq_closedForm]
  calc
    (1 + p) ^ uRMax‚ÇÅ * (1 + p) ^ uBMax‚ÇÅ * (1 - p) ^ remaining‚ÇÅ ‚â§
        ((1 + p) ^ uRMax‚ÇÇ * (1 + p) ^ uBMax‚ÇÇ) * (1 - p) ^ remaining‚ÇÅ := by
      have hmul :
          (1 + p) ^ uRMax‚ÇÅ * (1 + p) ^ uBMax‚ÇÅ ‚â§
            (1 + p) ^ uRMax‚ÇÇ * (1 + p) ^ uBMax‚ÇÇ := by
        exact mul_le_mul hR hB (pow_nonneg hpAdd0 _) (pow_nonneg hpAdd0 _)
      simpa [mul_assoc] using mul_le_mul_of_nonneg_right hmul (pow_nonneg hq0 _)
    _ ‚â§ ((1 + p) ^ uRMax‚ÇÇ * (1 + p) ^ uBMax‚ÇÇ) * (1 - p) ^ remaining‚ÇÇ := by
      exact mul_le_mul_of_nonneg_left hRem
        (mul_nonneg (pow_nonneg hpAdd0 _) (pow_nonneg hpAdd0 _))

theorem section4ProjectionChoiceMassSum_le_exp
    {p : ‚Ñù} {remaining uRMax uBMax : ‚Ñï} (hp0 : 0 ‚â§ p) (hp1 : p ‚â§ 1) :
    section4ProjectionChoiceMassSum p remaining uRMax uBMax ‚â§
      Real.exp (p * (uRMax : ‚Ñù) + p * (uBMax : ‚Ñù) - p * (remaining : ‚Ñù)) := by
  have honep_nonneg : 0 ‚â§ 1 + p := by linarith
  have hsub_nonneg : 0 ‚â§ 1 - p := by linarith
  have hR :
      (1 + p) ^ uRMax ‚â§ Real.exp (p * (uRMax : ‚Ñù)) := by
    have hbase : 1 + p ‚â§ Real.exp p := by simpa [add_comm] using Real.add_one_le_exp p
    calc
      (1 + p) ^ uRMax ‚â§ (Real.exp p) ^ uRMax := pow_le_pow_left‚ÇÄ honep_nonneg hbase _
      _ = Real.exp (p * (uRMax : ‚Ñù)) := by
        rw [‚Üê Real.exp_nat_mul]
        ring_nf
  have hB :
      (1 + p) ^ uBMax ‚â§ Real.exp (p * (uBMax : ‚Ñù)) := by
    have hbase : 1 + p ‚â§ Real.exp p := by simpa [add_comm] using Real.add_one_le_exp p
    calc
      (1 + p) ^ uBMax ‚â§ (Real.exp p) ^ uBMax := pow_le_pow_left‚ÇÄ honep_nonneg hbase _
      _ = Real.exp (p * (uBMax : ‚Ñù)) := by
        rw [‚Üê Real.exp_nat_mul]
        ring_nf
  have hremaining :
      (1 - p) ^ remaining ‚â§ Real.exp (-p * (remaining : ‚Ñù)) := by
    calc
      (1 - p) ^ remaining ‚â§ (Real.exp (-p)) ^ remaining := by
        exact pow_le_pow_left‚ÇÄ hsub_nonneg (Real.one_sub_le_exp_neg p) _
      _ = Real.exp ((remaining : ‚Ñù) * (-p)) := by rw [‚Üê Real.exp_nat_mul]
      _ = Real.exp (-p * (remaining : ‚Ñù)) := by ring_nf
  have hpair :
      ((1 + p) ^ uRMax) * ((1 + p) ^ uBMax) ‚â§
        Real.exp (p * (uRMax : ‚Ñù)) * Real.exp (p * (uBMax : ‚Ñù)) := by
    exact
      (mul_le_mul_of_nonneg_right hR (pow_nonneg honep_nonneg _)).trans
        (mul_le_mul_of_nonneg_left hB (by positivity))
  have htriple :
      (((1 + p) ^ uRMax) * ((1 + p) ^ uBMax)) * (1 - p) ^ remaining ‚â§
        (Real.exp (p * (uRMax : ‚Ñù)) * Real.exp (p * (uBMax : ‚Ñù))) *
          Real.exp (-p * (remaining : ‚Ñù)) := by
    exact
      (mul_le_mul_of_nonneg_right hpair (pow_nonneg hsub_nonneg _)).trans
        (mul_le_mul_of_nonneg_left hremaining (by positivity))
  calc
    section4ProjectionChoiceMassSum p remaining uRMax uBMax =
        (((1 + p) ^ uRMax) * ((1 + p) ^ uBMax)) * (1 - p) ^ remaining := by
      simpa [mul_assoc] using
        (section4ProjectionChoiceMassSum_eq_closedForm p remaining uRMax uBMax)
    _ ‚â§ (Real.exp (p * (uRMax : ‚Ñù)) * Real.exp (p * (uBMax : ‚Ñù))) *
          Real.exp (-p * (remaining : ‚Ñù)) := htriple
    _ = Real.exp (p * (uRMax : ‚Ñù) + p * (uBMax : ‚Ñù) - p * (remaining : ‚Ñù)) := by
      rw [‚Üê Real.exp_add, ‚Üê Real.exp_add]
      congr 1
      ring

theorem section4BernoulliMass_nonneg {p : ‚Ñù} {uR uB remaining : ‚Ñï}
    (hp0 : 0 ‚â§ p) (hp1 : p ‚â§ 1) :
