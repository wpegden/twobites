@[simp] theorem mem_redProjectionImage_inl (C : ConstructionData n m) {I : Finset (Fin n)}
    {r r' : Fin m} :
    r' ‚àà C.redProjectionImage I (Sum.inl r) ‚Üî C.redBase.Adj r r' ‚àß r' ‚àà C.redImage I := by
  constructor
  ¬∑ intro hr'
    rcases Finset.mem_image.1 hr' with ‚ü®v, hvX, hrv‚ü©
    rcases (C.mem_X_red).1 hvX with ‚ü®hvI, hAdj‚ü©
    rw [hrv] at hAdj
    refine ‚ü®hAdj, ?_‚ü©
    exact (C.mem_redImage).2 ‚ü®v, hvI, hrv‚ü©
  ¬∑ rintro ‚ü®hAdj, hrI‚ü©
    rcases (C.mem_redImage).1 hrI with ‚ü®v, hvI, hrv‚ü©
    refine Finset.mem_image.2 ‚ü®v, ?_, hrv‚ü©
    have hAdj' : C.redBase.Adj r (C.redProj v) := by
      rwa [hrv]
    exact (C.mem_X_red).2 ‚ü®hvI, hAdj'‚ü©

@[simp] theorem mem_blueProjectionImage_inr (C : ConstructionData n m) {I : Finset (Fin n)}
    {b b' : Fin m} :
    b' ‚àà C.blueProjectionImage I (Sum.inr b) ‚Üî
      C.blueBase.Adj b b' ‚àß b' ‚àà C.blueImage I := by
  constructor
  ¬∑ intro hb'
    rcases Finset.mem_image.1 hb' with ‚ü®v, hvX, hbv‚ü©
    rcases (C.mem_X_blue).1 hvX with ‚ü®hvI, hAdj‚ü©
    rw [hbv] at hAdj
    refine ‚ü®hAdj, ?_‚ü©
    exact (C.mem_blueImage).2 ‚ü®v, hvI, hbv‚ü©
  ¬∑ rintro ‚ü®hAdj, hbI‚ü©
    rcases (C.mem_blueImage).1 hbI with ‚ü®v, hvI, hbv‚ü©
    refine Finset.mem_image.2 ‚ü®v, ?_, hbv‚ü©
    have hAdj' : C.blueBase.Adj b (C.blueProj v) := by
      rwa [hbv]
    exact (C.mem_X_blue).2 ‚ü®hvI, hAdj'‚ü©

@[simp] theorem mem_redProjectionImage_inr (C : ConstructionData n m) {I : Finset (Fin n)}
    {b r : Fin m} :
    r ‚àà C.redProjectionImage I (Sum.inr b) ‚Üî
      ‚àÉ v ‚àà I, C.blueBase.Adj b (C.blueProj v) ‚àß C.redProj v = r := by
  constructor
  ¬∑ intro hr
    rcases Finset.mem_image.1 hr with ‚ü®v, hvX, hrv‚ü©
