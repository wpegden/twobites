theorem disjoint_filter_isRed_filter_isBlue (A : Finset (BaseVertex m)) :
    Disjoint (A.filter IsRedBaseVertex) (A.filter IsBlueBaseVertex) := by
  classical
  refine Finset.disjoint_left.2 ?_
