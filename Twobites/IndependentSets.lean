/-- The witness-size right-branch error condition for the `H_I ‚à© V_R` cross term. -/
def paperHugeBlueCrossWitnessRightErrorProp (C : ConstructionData n m) (I : Finset (Fin n))
    (Œ∫ Œµ1 : ‚Ñù) (witnessSize degreeBound projCodegreeBound cap : ‚Ñï) : Prop :=
  (((Twobites.paperKNat Œ∫ n - (C.redImage I).card - cap : ‚Ñï) : ‚Ñù) *
      (witnessSize * degreeBound + witnessSize.choose 2 * projCodegreeBound) +
    (((witnessSize * degreeBound + witnessSize.choose 2 * projCodegreeBound).choose 2 :
      ‚Ñï) : ‚Ñù) ‚â§
    Œµ1 * C.paperHugeBlueCrossRightTarget I Œ∫ cap)

/-- The split right-branch witness-error condition for the `H_I ‚à© V_R` cross term, keeping the
union-size slack linear while only the projected-overlap slack pays a quadratic loss. -/
def paperHugeBlueCrossWitnessRightSplitErrorProp (C : ConstructionData n m) (I : Finset (Fin n))
    (Œ∫ Œµ1 : ‚Ñù) (unionSlack overlapError cap : ‚Ñï) : Prop :=
  (((3 : ‚Ñù) / 2) *
        (((Twobites.paperKNat Œ∫ n - (C.redImage I).card - cap : ‚Ñï) : ‚Ñù) *
          (unionSlack : ‚Ñù)) +
      ((((Twobites.paperKNat Œ∫ n - (C.redImage I).card - cap + unionSlack : ‚Ñï) : ‚Ñù) *
          (overlapError : ‚Ñù)) +
        (((overlapError.choose 2 : ‚Ñï) : ‚Ñù)))) ‚â§
    Œµ1 * C.paperHugeBlueCrossRightTarget I Œ∫ cap

