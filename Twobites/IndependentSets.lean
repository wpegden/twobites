theorem section4URedCondPairSet_card_le_redProjectionPairCount_of_indep
    (C : ConstructionData n m) {I : Finset (Fin n)} {A : Finset (BaseVertex m)}
    (hindep :
      ‚àÄ {v w : Fin n}, v ‚àà I ‚Üí w ‚àà I ‚Üí v ‚âÝ w ‚Üí ¬¨ C.finalGraph.Adj v w) :
