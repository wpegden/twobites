namespace Twobites

open scoped BigOperators

/-- The paper's ambient vertex type `V_R ‚à™ V_B`, represented as a tagged disjoint union. -/
abbrev BaseVertex (m : ‚Ñï) := Fin m ‚äï Fin m

/-- Predicate selecting the red side `V_R` inside `V_R ‚à™ V_B`. -/
def IsRedBaseVertex {m : ‚Ñï} : BaseVertex m ‚Üí Prop
  | Sum.inl _ => True
  | Sum.inr _ => False

/-- Predicate selecting the blue side `V_B` inside `V_R ‚à™ V_B`. -/
def IsBlueBaseVertex {m : ‚Ñï} : BaseVertex m ‚Üí Prop
  | Sum.inl _ => False
  | Sum.inr _ => True

instance {m : ‚Ñï} : DecidablePred (@IsRedBaseVertex m)
  | Sum.inl _ => isTrue trivial
  | Sum.inr _ => isFalse (by simp [IsRedBaseVertex])

instance {m : ‚Ñï} : DecidablePred (@IsBlueBaseVertex m)
  | Sum.inl _ => isFalse (by simp [IsBlueBaseVertex])
  | Sum.inr _ => isTrue trivial

@[simp] theorem isRedBaseVertex_inl {m : ‚Ñï} (r : Fin m) : IsRedBaseVertex (Sum.inl r) := trivial
@[simp] theorem not_isRedBaseVertex_inr {m : ‚Ñï} (b : Fin m) :
    ¬¨ IsRedBaseVertex (Sum.inr b) := by simp [IsRedBaseVertex]
@[simp] theorem isBlueBaseVertex_inr {m : ‚Ñï} (b : Fin m) : IsBlueBaseVertex (Sum.inr b) := trivial
@[simp] theorem not_isBlueBaseVertex_inl {m : ‚Ñï} (r : Fin m) :
    ¬¨ IsBlueBaseVertex (Sum.inl r) := by simp [IsBlueBaseVertex]

namespace ConstructionData

variable {n m : ‚Ñï}

noncomputable section

noncomputable instance : DecidableEq (ConstructionData n m) := Classical.decEq _

/-- Paper notation `X_v(I)`: vertices of `I` lying in the lifted neighborhood of the base vertex
`v ‚àà V_R ‚à™ V_B`. -/
def X (C : ConstructionData n m) (I : Finset (Fin n)) : BaseVertex m ‚Üí Finset (Fin n) := by
  classical
  intro x
  cases x with
  | inl r => exact I.filter fun v => C.redBase.Adj r (C.redProj v)
  | inr b => exact I.filter fun v => C.blueBase.Adj b (C.blueProj v)

/-- Paper notation `X_v^+(I)`: the forward-neighborhood analogue of `X_v(I)` used for
monochromatic deletions. -/
def XPlus (C : ConstructionData n m) (I : Finset (Fin n)) : BaseVertex m ‚Üí Finset (Fin n) := by
  classical
  intro x
  cases x with
  | inl r => exact I.filter fun v => C.redBase.Adj r (C.redProj v) ‚àß r < C.redProj v
  | inr b => exact I.filter fun v => C.blueBase.Adj b (C.blueProj v) ‚àß b < C.blueProj v

/-- Paper notation `|X_v(I)|`. -/
def xCard (C : ConstructionData n m) (I : Finset (Fin n)) (x : BaseVertex m) : ‚Ñï :=
  (C.X I x).card

/-- Paper notation `|X_v^+(I)|`. -/
def xPlusCard (C : ConstructionData n m) (I : Finset (Fin n)) (x : BaseVertex m) : ‚Ñï :=
  (C.XPlus I x).card

/-- The red-coordinate projection `œÄ_R(X_v(I))` appearing in the huge-case bounds. -/
def redProjectionImage (C : ConstructionData n m) (I : Finset (Fin n))
    (x : BaseVertex m) : Finset (Fin m) :=
  (C.X I x).image C.redProj

/-- The blue-coordinate projection `œÄ_B(X_v(I))` appearing in the huge-case bounds. -/
def blueProjectionImage (C : ConstructionData n m) (I : Finset (Fin n))
    (x : BaseVertex m) : Finset (Fin m) :=
  (C.X I x).image C.blueProj

/-- The deterministic Section 3 event `ùíü`, restricted to the combinatorial bounds that the current
formalization uses directly. It packages fiber bounds, lifted-neighborhood codegrees, same-color
projection bounds, and the projected codegrees that feed the huge-case estimates. -/
structure GoodEventD (C : ConstructionData n m) (fiberBound degreeBound codegreeBound
    projCodegreeBound : ‚Ñï) : Prop where
  redFiberBound : ‚àÄ r : Fin m, (C.redFiber r).card ‚â§ fiberBound
  blueFiberBound : ‚àÄ b : Fin m, (C.blueFiber b).card ‚â§ fiberBound
  redProjectionBound : ‚àÄ r : Fin m,
    (C.redProjectionImage Finset.univ (Sum.inl r)).card ‚â§ degreeBound
  blueProjectionBound : ‚àÄ b : Fin m,
    (C.blueProjectionImage Finset.univ (Sum.inr b)).card ‚â§ degreeBound
  xInterBound : ‚àÄ x y : BaseVertex m, x ‚âÝ y ‚Üí
    (C.X Finset.univ x ‚à© C.X Finset.univ y).card ‚â§ codegreeBound
  blueProjectionInterBound : ‚àÄ r r' : Fin m, r ‚âÝ r' ‚Üí
    (C.blueProjectionImage Finset.univ (Sum.inl r) ‚à©
      C.blueProjectionImage Finset.univ (Sum.inl r')).card ‚â§ projCodegreeBound
  redProjectionInterBound : ‚àÄ b b' : Fin m, b ‚âÝ b' ‚Üí
    (C.redProjectionImage Finset.univ (Sum.inr b) ‚à©
      C.redProjectionImage Finset.univ (Sum.inr b')).card ‚â§ projCodegreeBound

/-- The finite event family of construction outcomes satisfying the deterministic pseudorandomness
package `GoodEventD`. This is the unweighted event set that the still-missing probability layer
must eventually equip with positive mass. -/
noncomputable def goodEventDSet (n m fiberBound degreeBound codegreeBound projCodegreeBound : ‚Ñï) :
    Finset (ConstructionData n m) :=
  by
    classical
    exact (ConstructionData.sampleSpace n m).filter fun C =>
      GoodEventD C fiberBound degreeBound codegreeBound projCodegreeBound

@[simp] theorem mem_goodEventDSet_iff
    {n m fiberBound degreeBound codegreeBound projCodegreeBound : ‚Ñï} {C : ConstructionData n m} :
    C ‚àà goodEventDSet n m fiberBound degreeBound codegreeBound projCodegreeBound ‚Üî
      GoodEventD C fiberBound degreeBound codegreeBound projCodegreeBound := by
  classical
  simp [goodEventDSet, ConstructionData.sampleSpace]

/-- The edge finset of a construction-stage base graph, packaged so it can be referenced inside
`Finset.image` without reopening local `Fintype` instances for `edgeSet`. -/
noncomputable def constructionGraphEdgeFinset
    (G : SimpleGraph (Fin m)) : Finset (Sym2 (Fin m)) := by
  classical
  exact G.edgeFinset

/-- The Bernoulli weight of one base graph in the paper's first-stage random construction. -/
def constructionGraphBernoulliWeight (p : ‚Ñù) (G : SimpleGraph (Fin m)) : ‚Ñù :=
  p ^ (constructionGraphEdgeFinset G).card *
    (1 - p) ^ (Fintype.card (Sym2 (Fin m)) - (constructionGraphEdgeFinset G).card)

/-- The uniform weight of the paper's random embedding `œÄ`. -/
def constructionEmbeddingUniformWeight (n m : ‚Ñï) : ‚Ñù :=
  (((Fintype.card (Fin n ‚Ü™ Fin m √ó Fin m)) : ‚Ñï) : ‚Ñù)‚Åª¬π

/-- The product weight of a full construction outcome `(G_R,G_B,œÄ)`. This is the finite weighted
sample-space interface that the final global probability layer will use. -/
def constructionProductWeight (p : ‚Ñù) (C : ConstructionData n m) : ‚Ñù :=
  constructionGraphBernoulliWeight p C.redBase *
    constructionGraphBernoulliWeight p C.blueBase *
      constructionEmbeddingUniformWeight n m

/-- The paper-scale specialization of `constructionProductWeight`. -/
def paperConstructionWeight (Œ≤ : ‚Ñù) (n m : ‚Ñï) (C : ConstructionData n m) : ‚Ñù :=
  constructionProductWeight (Twobites.paperP Œ≤ n) C

/-- Weighted mass of a finite event family in the construction sample space. -/
def constructionEventMass (w : ConstructionData n m ‚Üí ‚Ñù) (E : Finset (ConstructionData n m)) : ‚Ñù :=
  ‚àë C ‚àà E, w C

@[simp] theorem constructionEventMass_empty (w : ConstructionData n m ‚Üí ‚Ñù) :
    constructionEventMass w (‚àÖ : Finset (ConstructionData n m)) = 0 := by
  simp [constructionEventMass]

theorem constructionGraphBernoulliWeight_nonneg {p : ‚Ñù} (hp0 : 0 ‚â§ p) (hp1 : p ‚â§ 1)
    (G : SimpleGraph (Fin m)) :
    0 ‚â§ constructionGraphBernoulliWeight p G := by
  have hq : 0 ‚â§ 1 - p := sub_nonneg.mpr hp1
  unfold constructionGraphBernoulliWeight
  positivity

theorem constructionGraphBernoulliWeight_pos {p : ‚Ñù} (hp0 : 0 < p) (hp1 : p < 1)
    (G : SimpleGraph (Fin m)) :
    0 < constructionGraphBernoulliWeight p G := by
  have hq : 0 < 1 - p := sub_pos.mpr hp1
  unfold constructionGraphBernoulliWeight
  positivity

@[simp] theorem constructionGraphBernoulliWeight_bot_eq (p : ‚Ñù) :
    constructionGraphBernoulliWeight p (‚ä• : SimpleGraph (Fin m)) =
      (1 - p) ^ Fintype.card (Sym2 (Fin m)) := by
  have hbot : constructionGraphEdgeFinset (‚ä• : SimpleGraph (Fin m)) = ‚àÖ := by
    simp [constructionGraphEdgeFinset]
  rw [constructionGraphBernoulliWeight, hbot]
  simp

theorem constructionGraph_edgeFinset_image_univ_eq_powerset_top (m : ‚Ñï) :
    (Finset.univ.image fun G : SimpleGraph (Fin m) => constructionGraphEdgeFinset G) =
      ((‚ä§ : SimpleGraph (Fin m)).edgeFinset).powerset := by
  classical
  ext s
  constructor
  ¬∑ intro hs
    rcases Finset.mem_image.1 hs with ‚ü®G, -, rfl‚ü©
    refine Finset.mem_powerset.2 ?_
    simpa [SimpleGraph.edgeFinset_top] using
      (SimpleGraph.edgeFinset_mono (show G ‚â§ (‚ä§ : SimpleGraph (Fin m)) by
        exact le_top) : G.edgeFinset ‚äÜ (‚ä§ : SimpleGraph (Fin m)).edgeFinset)
  ¬∑ intro hs
    refine Finset.mem_image.2 ?_
    refine ‚ü®SimpleGraph.fromEdgeSet (s : Set (Sym2 (Fin m))), by simp, ?_‚ü©
    ext e
    constructor
    ¬∑ intro he
      have he' :
          e ‚àà (SimpleGraph.fromEdgeSet (s : Set (Sym2 (Fin m))) : SimpleGraph (Fin m)).edgeSet := by
        simpa [constructionGraphEdgeFinset] using he
      exact (by simpa [SimpleGraph.edgeSet_fromEdgeSet] using he' : e ‚àà s ‚àß ¬¨ e.IsDiag).1
    ¬∑ intro he
      have htop : e ‚àà (‚ä§ : SimpleGraph (Fin m)).edgeFinset := (Finset.mem_powerset.1 hs) he
      have hdiag : ¬¨ e.IsDiag :=
        SimpleGraph.not_isDiag_of_mem_edgeFinset (G := (‚ä§ : SimpleGraph (Fin m))) htop
      have he' :
          e ‚àà (SimpleGraph.fromEdgeSet (s : Set (Sym2 (Fin m))) : SimpleGraph (Fin m)).edgeSet := by
        simpa [SimpleGraph.edgeSet_fromEdgeSet, hdiag] using
          (show e ‚àà s ‚àß ¬¨ e.IsDiag from ‚ü®he, hdiag‚ü©)
      simpa [constructionGraphEdgeFinset] using he'

theorem constructionGraphBernoulliWeight_sum_univ_eq (p : ‚Ñù) :
    (‚àë G : SimpleGraph (Fin m), constructionGraphBernoulliWeight p G) = (1 - p) ^ m := by
  classical
  let topEdges : Finset (Sym2 (Fin m)) := (‚ä§ : SimpleGraph (Fin m)).edgeFinset
  have himage :
      (Finset.univ.image fun G : SimpleGraph (Fin m) => constructionGraphEdgeFinset G) =
        topEdges.powerset := by
    simpa [topEdges] using constructionGraph_edgeFinset_image_univ_eq_powerset_top m
  have hcard :
      Fintype.card (Sym2 (Fin m)) = topEdges.card + m := by
    rw [Sym2.card, show topEdges.card = m.choose 2 by
      simpa [topEdges] using (SimpleGraph.card_edgeFinset_top_eq_card_choose_two (V := Fin m))]
    simpa [Nat.add_comm] using Nat.choose_succ_succ' m 1
  calc
    Finset.sum (Finset.univ : Finset (SimpleGraph (Fin m)))
        (fun G => constructionGraphBernoulliWeight p G)
        = Finset.sum topEdges.powerset
            (fun s => p ^ s.card * (1 - p) ^ (Fintype.card (Sym2 (Fin m)) - s.card)) := by
          rw [‚Üê himage]
          symm
          refine (Finset.sum_image ?hinj).trans ?_
          ¬∑ intro G _ H _ hGH
            have hGH' : G.edgeFinset = H.edgeFinset := by
              simpa [constructionGraphEdgeFinset] using hGH
            exact (SimpleGraph.edgeFinset_inj).1 hGH'
          ¬∑ refine Finset.sum_congr rfl ?_
            intro G hG
            rw [constructionGraphBernoulliWeight, constructionGraphEdgeFinset]
    _ = Finset.sum topEdges.powerset
          (fun s => (1 - p) ^ m * (p ^ s.card * (1 - p) ^ (topEdges.card - s.card))) := by
          refine Finset.sum_congr rfl ?_
          intro s hs
          have hsle : s.card ‚â§ topEdges.card := by
            exact Finset.card_le_card (Finset.mem_powerset.1 hs)
          have hsplit : topEdges.card + m - s.card = m + (topEdges.card - s.card) := by
            omega
          rw [hcard, hsplit, pow_add]
          ring
    _ = (1 - p) ^ m * Finset.sum topEdges.powerset
          (fun s => p ^ s.card * (1 - p) ^ (topEdges.card - s.card)) := by
          rw [Finset.mul_sum]
    _ = (1 - p) ^ m * (p + (1 - p)) ^ topEdges.card := by
          rw [Finset.sum_pow_mul_eq_add_pow]
    _ = (1 - p) ^ m := by simp

/-- The finite weighted mass of base graphs satisfying a prescribed forced-edge / forced-nonedge
pattern on canonical edge pairs. -/
def constructionGraphConstraintMass
    (p : ‚Ñù) (required forbidden : Finset (Sym2 (Fin m))) : ‚Ñù :=
  ‚àë G : SimpleGraph (Fin m),
    if required ‚äÜ constructionGraphEdgeFinset G ‚àß
        Disjoint forbidden (constructionGraphEdgeFinset G) then
      constructionGraphBernoulliWeight p G
    else
      0

theorem constructionGraphConstraintMass_eq
    (p : ‚Ñù) (required forbidden : Finset (Sym2 (Fin m)))
    (hrequired : required ‚äÜ (‚ä§ : SimpleGraph (Fin m)).edgeFinset)
    (hforbidden : forbidden ‚äÜ (‚ä§ : SimpleGraph (Fin m)).edgeFinset)
    (hdisj : Disjoint required forbidden) :
    constructionGraphConstraintMass p required forbidden =
      (1 - p) ^ m * (p ^ required.card * (1 - p) ^ forbidden.card) := by
  classical
  let topEdges : Finset (Sym2 (Fin m)) := (‚ä§ : SimpleGraph (Fin m)).edgeFinset
  let free : Finset (Sym2 (Fin m)) := topEdges \ (required ‚à™ forbidden)
  have himage :
      (Finset.univ.image fun G : SimpleGraph (Fin m) => constructionGraphEdgeFinset G) =
        topEdges.powerset := by
    simpa [topEdges] using constructionGraph_edgeFinset_image_univ_eq_powerset_top m
  have hcard :
      Fintype.card (Sym2 (Fin m)) = topEdges.card + m := by
    rw [Sym2.card, show topEdges.card = m.choose 2 by
      simpa [topEdges] using (SimpleGraph.card_edgeFinset_top_eq_card_choose_two (V := Fin m))]
    simpa [Nat.add_comm] using Nat.choose_succ_succ' m 1
  have hfree_subset : free ‚äÜ topEdges := by
    intro e he
    exact (Finset.mem_sdiff.1 he).1
  have hrequired_subset_sdiff : required ‚äÜ topEdges \ forbidden := by
    intro e heReq
    refine Finset.mem_sdiff.2 ‚ü®hrequired heReq, ?_‚ü©
    intro heForb
    exact (Finset.disjoint_left.1 hdisj) heReq heForb
  have hrequired_free_disjoint : Disjoint required free := by
    refine Finset.disjoint_left.2 ?_
    intro e heReq heFree
    have hnot : e ‚àâ required ‚à™ forbidden := (Finset.mem_sdiff.1 heFree).2
    exact hnot (Finset.mem_union.2 (Or.inl heReq))
  have hforbidden_free_disjoint : Disjoint forbidden free := by
    refine Finset.disjoint_left.2 ?_
    intro e heForb heFree
    have hnot : e ‚àâ required ‚à™ forbidden := (Finset.mem_sdiff.1 heFree).2
    exact hnot (Finset.mem_union.2 (Or.inr heForb))
  have hfree_eq : free = (topEdges \ forbidden) \ required := by
    ext e
    simp [free, and_assoc, and_comm]
  have hfilter_eq :
      topEdges.powerset.filter
          (fun s => required ‚äÜ s ‚àß Disjoint forbidden s) =
        (free.powerset.image fun t => required ‚à™ t) := by
    calc
      topEdges.powerset.filter (fun s => required ‚äÜ s ‚àß Disjoint forbidden s) =
          Finset.Icc required (topEdges \ forbidden) := by
            ext s
            simp only [Finset.mem_filter, Finset.mem_powerset, Finset.mem_Icc,
              Finset.disjoint_left]
            constructor
            ¬∑ rintro ‚ü®hsTop, hsReq, hsDisj‚ü©
              refine ‚ü®hsReq, ?_‚ü©
              intro e he
              refine Finset.mem_sdiff.2 ‚ü®hsTop he, ?_‚ü©
              intro heForb
              exact hsDisj heForb he
            ¬∑ rintro ‚ü®hsReq, hsSub‚ü©
              refine ‚ü®?_, hsReq, ?_‚ü©
              ¬∑ intro e he
                exact (Finset.mem_sdiff.1 (hsSub he)).1
              ¬∑ intro e heForb heS
                exact (Finset.mem_sdiff.1 (hsSub heS)).2 heForb
      _ = (((topEdges \ forbidden) \ required).powerset.image fun t => required ‚à™ t) := by
            simpa using Finset.Icc_eq_image_powerset hrequired_subset_sdiff
      _ = (free.powerset.image fun t => required ‚à™ t) := by
            simp [hfree_eq]
  calc
    constructionGraphConstraintMass p required forbidden =
        ‚àë G : SimpleGraph (Fin m),
          if required ‚äÜ constructionGraphEdgeFinset G ‚àß
              Disjoint forbidden (constructionGraphEdgeFinset G) then
            constructionGraphBernoulliWeight p G
          else
            0 := by
      rfl
    _ =
        ‚àë s ‚àà topEdges.powerset.filter
            (fun s => required ‚äÜ s ‚àß Disjoint forbidden s),
          p ^ s.card * (1 - p) ^ (Fintype.card (Sym2 (Fin m)) - s.card) := by
      calc
        (‚àë G : SimpleGraph (Fin m),
            if required ‚äÜ constructionGraphEdgeFinset G ‚àß
                Disjoint forbidden (constructionGraphEdgeFinset G) then
              constructionGraphBernoulliWeight p G
            else
              0) =
            ‚àë s ‚àà Finset.image (fun G : SimpleGraph (Fin m) => constructionGraphEdgeFinset G)
                (Finset.univ : Finset (SimpleGraph (Fin m))),
              if required ‚äÜ s ‚àß Disjoint forbidden s then
                p ^ s.card * (1 - p) ^ (Fintype.card (Sym2 (Fin m)) - s.card)
              else
                0 := by
              symm
              refine (Finset.sum_image ?_).trans ?_
              ¬∑ intro G _ H _ hGH
                have hGH' : G.edgeFinset = H.edgeFinset := by
                  simpa [constructionGraphEdgeFinset] using hGH
                exact (SimpleGraph.edgeFinset_inj).1 hGH'
              ¬∑ refine Finset.sum_congr rfl ?_
                intro G hG
                by_cases hcond :
                    required ‚äÜ constructionGraphEdgeFinset G ‚àß
                      Disjoint forbidden (constructionGraphEdgeFinset G)
                ¬∑ simp [constructionGraphBernoulliWeight, constructionGraphEdgeFinset]
                ¬∑ simp [hcond]
        _ =
            ‚àë s ‚àà topEdges.powerset.filter
                (fun s => required ‚äÜ s ‚àß Disjoint forbidden s),
              p ^ s.card * (1 - p) ^ (Fintype.card (Sym2 (Fin m)) - s.card) := by
              rw [himage, Finset.sum_filter]
    _ =
        ‚àë t ‚àà free.powerset,
          p ^ (required ‚à™ t).card *
            (1 - p) ^ (Fintype.card (Sym2 (Fin m)) - (required ‚à™ t).card) := by
      rw [hfilter_eq]
      refine Finset.sum_image ?_
      intro t ht u hu hEq
      have htDisj : Disjoint required t := by
        refine Finset.disjoint_left.2 ?_
        intro e heReq heT
        exact (Finset.disjoint_left.1 hrequired_free_disjoint) heReq
          ((Finset.mem_powerset.1 ht) heT)
      have huDisj : Disjoint required u := by
        refine Finset.disjoint_left.2 ?_
        intro e heReq heU
        exact (Finset.disjoint_left.1 hrequired_free_disjoint) heReq
          ((Finset.mem_powerset.1 hu) heU)
      have htEq : (required ‚à™ t) \ required = t := by
        ext e
        constructor
        ¬∑ intro he
          rcases Finset.mem_sdiff.1 he with ‚ü®heUnion, hnotReq‚ü©
          rcases Finset.mem_union.1 heUnion with heReq | heT
          ¬∑ exact False.elim (hnotReq heReq)
          ¬∑ exact heT
        ¬∑ intro he
          exact Finset.mem_sdiff.2 ‚ü®Finset.mem_union.2 (Or.inr he), by
            intro heReq
            exact (Finset.disjoint_left.1 htDisj) heReq he‚ü©
      have huEq : (required ‚à™ u) \ required = u := by
        ext e
        constructor
        ¬∑ intro he
          rcases Finset.mem_sdiff.1 he with ‚ü®heUnion, hnotReq‚ü©
          rcases Finset.mem_union.1 heUnion with heReq | heU
          ¬∑ exact False.elim (hnotReq heReq)
          ¬∑ exact heU
        ¬∑ intro he
          exact Finset.mem_sdiff.2 ‚ü®Finset.mem_union.2 (Or.inr he), by
            intro heReq
            exact (Finset.disjoint_left.1 huDisj) heReq he‚ü©
      have hsdiff : (required ‚à™ t) \ required = (required ‚à™ u) \ required := by
        simp [hEq]
      simpa [htEq, huEq] using hsdiff
    _ =
        ‚àë t ‚àà free.powerset,
          (1 - p) ^ m * (p ^ required.card * (1 - p) ^ forbidden.card) *
            (p ^ t.card * (1 - p) ^ (free.card - t.card)) := by
      refine Finset.sum_congr rfl ?_
      intro t ht
      have htSubset : t ‚äÜ free := Finset.mem_powerset.1 ht
      have htDisjReq : Disjoint required t := by
        refine Finset.disjoint_left.2 ?_
        intro e heReq heT
        exact (Finset.disjoint_left.1 hrequired_free_disjoint) heReq (htSubset heT)
      have htDisjForb : Disjoint forbidden t := by
        refine Finset.disjoint_left.2 ?_
        intro e heForb heT
        exact (Finset.disjoint_left.1 hforbidden_free_disjoint) heForb (htSubset heT)
      have hcardUnion : (required ‚à™ t).card = required.card + t.card := by
        simpa using Finset.card_union_of_disjoint htDisjReq
      have hcardTop :
          topEdges.card = free.card + (required ‚à™ forbidden).card := by
        have hsubsetUnion : required ‚à™ forbidden ‚äÜ topEdges := by
          intro e he
          rcases Finset.mem_union.1 he with heReq | heForb
          ¬∑ exact hrequired heReq
          ¬∑ exact hforbidden heForb
        simpa [free, Nat.add_comm] using
          (Finset.card_sdiff_add_card_eq_card hsubsetUnion).symm
      have hcardReqForb : (required ‚à™ forbidden).card = required.card + forbidden.card := by
        simpa using Finset.card_union_of_disjoint hdisj
      have htle : t.card ‚â§ free.card := Finset.card_le_card htSubset
      have hcardSym2 :
          Fintype.card (Sym2 (Fin m)) - (required.card + t.card) =
            m + forbidden.card + (free.card - t.card) := by
        rw [hcard, hcardTop, hcardReqForb]
        omega
      rw [hcardUnion, hcardSym2, pow_add, pow_add, pow_add]
      ring
    _ =
        (1 - p) ^ m * (p ^ required.card * (1 - p) ^ forbidden.card) *
          (‚àë t ‚àà free.powerset, p ^ t.card * (1 - p) ^ (free.card - t.card)) := by
      rw [‚Üê Finset.mul_sum]
    _ =
        (1 - p) ^ m * (p ^ required.card * (1 - p) ^ forbidden.card) *
          (p + (1 - p)) ^ free.card := by
      rw [Finset.sum_pow_mul_eq_add_pow]
    _ =
        (1 - p) ^ m * (p ^ required.card * (1 - p) ^ forbidden.card) := by
      simp

theorem constructionGraphConstraintMass_le
    (p : ‚Ñù) (required forbidden : Finset (Sym2 (Fin m)))
    (hp0 : 0 ‚â§ p) (hp1 : p ‚â§ 1)
    (hrequired : required ‚äÜ (‚ä§ : SimpleGraph (Fin m)).edgeFinset)
    (hforbidden : forbidden ‚äÜ (‚ä§ : SimpleGraph (Fin m)).edgeFinset)
    (hdisj : Disjoint required forbidden) :
    constructionGraphConstraintMass p required forbidden ‚â§
      p ^ required.card * (1 - p) ^ forbidden.card := by
  rw [constructionGraphConstraintMass_eq p required forbidden hrequired hforbidden hdisj]
  have hfac_nonneg : 0 ‚â§ (1 - p) ^ m := by
    exact pow_nonneg (sub_nonneg.mpr hp1) _
  have hfac_le_one : (1 - p) ^ m ‚â§ 1 := by
    exact pow_le_one‚ÇÄ (sub_nonneg.mpr hp1) (by linarith : 1 - p ‚â§ (1 : ‚Ñù))
  have hterm_nonneg : 0 ‚â§ p ^ required.card * (1 - p) ^ forbidden.card := by
    exact mul_nonneg (pow_nonneg hp0 _) (pow_nonneg (sub_nonneg.mpr hp1) _)
  calc
    (1 - p) ^ m * (p ^ required.card * (1 - p) ^ forbidden.card) ‚â§
        1 * (p ^ required.card * (1 - p) ^ forbidden.card) := by
          exact mul_le_mul_of_nonneg_right hfac_le_one hterm_nonneg
    _ = p ^ required.card * (1 - p) ^ forbidden.card := by ring

theorem constructionGraphConstraintMass_nonneg
    {p : ‚Ñù} (hp0 : 0 ‚â§ p) (hp1 : p ‚â§ 1)
    (required forbidden : Finset (Sym2 (Fin m))) :
    0 ‚â§ constructionGraphConstraintMass p required forbidden := by
  classical
  unfold constructionGraphConstraintMass
  refine Finset.sum_nonneg ?_
  intro G hG
  by_cases hcond :
      required ‚äÜ constructionGraphEdgeFinset G ‚àß
        Disjoint forbidden (constructionGraphEdgeFinset G)
  ¬∑ simp [hcond, constructionGraphBernoulliWeight_nonneg hp0 hp1]
  ¬∑ simp [hcond]

theorem constructionGraphBernoulliWeight_le_constructionGraphConstraintMass_of_subset_disjoint
    {p : ‚Ñù} (hp0 : 0 ‚â§ p) (hp1 : p ‚â§ 1)
    (G : SimpleGraph (Fin m)) (required forbidden : Finset (Sym2 (Fin m)))
    (hrequired : required ‚äÜ constructionGraphEdgeFinset G)
    (hforbidden : Disjoint forbidden (constructionGraphEdgeFinset G)) :
    constructionGraphBernoulliWeight p G ‚â§
      constructionGraphConstraintMass p required forbidden := by
  classical
  unfold constructionGraphConstraintMass
  have hnonneg :
      ‚àÄ H ‚àà (Finset.univ : Finset (SimpleGraph (Fin m))),
        0 ‚â§
          (if required ‚äÜ constructionGraphEdgeFinset H ‚àß
                Disjoint forbidden (constructionGraphEdgeFinset H) then
              constructionGraphBernoulliWeight p H
            else
              0) := by
    intro H hH
    by_cases hcond :
        required ‚äÜ constructionGraphEdgeFinset H ‚àß
          Disjoint forbidden (constructionGraphEdgeFinset H)
    ¬∑ simp [hcond, constructionGraphBernoulliWeight_nonneg hp0 hp1]
    ¬∑ simp [hcond]
  have hsingle :=
    Finset.single_le_sum hnonneg (show G ‚àà (Finset.univ : Finset (SimpleGraph (Fin m))) by simp)
  simpa [hrequired, hforbidden] using hsingle

theorem constructionEmbeddingUniformWeight_nonneg (n m : ‚Ñï) :
    0 ‚â§ constructionEmbeddingUniformWeight n m := by
  unfold constructionEmbeddingUniformWeight
  positivity

theorem constructionEmbeddingUniformWeight_sum_univ_eq_one (e : Fin n ‚Ü™ Fin m √ó Fin m) :
    (‚àë _ : Fin n ‚Ü™ Fin m √ó Fin m, constructionEmbeddingUniformWeight n m) = 1 := by
  classical
  unfold constructionEmbeddingUniformWeight
  have hcardposNat : 0 < Fintype.card (Fin n ‚Ü™ Fin m √ó Fin m) := by
    exact Fintype.card_pos_iff.mpr ‚ü®e‚ü©
  have hcardposReal : 0 < (((Fintype.card (Fin n ‚Ü™ Fin m √ó Fin m)) : ‚Ñï) : ‚Ñù) := by
    exact_mod_cast hcardposNat
  calc
    (‚àë _ : Fin n ‚Ü™ Fin m √ó Fin m, (((Fintype.card (Fin n ‚Ü™ Fin m √ó Fin m)) : ‚Ñï) : ‚Ñù)‚Åª¬π)
        = ((Fintype.card (Fin n ‚Ü™ Fin m √ó Fin m) : ‚Ñï) : ‚Ñù) *
            (((Fintype.card (Fin n ‚Ü™ Fin m √ó Fin m)) : ‚Ñï) : ‚Ñù)‚Åª¬π := by
              simp
    _ = 1 := by
          field_simp [hcardposReal.ne']

theorem constructionEmbeddingUniformWeight_pos (C : ConstructionData n m) :
    0 < constructionEmbeddingUniformWeight n m := by
  unfold constructionEmbeddingUniformWeight
  have hcard : 0 < Fintype.card (Fin n ‚Ü™ Fin m √ó Fin m) := by
    exact Fintype.card_pos_iff.mpr ‚ü®C.embedding‚ü©
  have hreal : 0 < (((Fintype.card (Fin n ‚Ü™ Fin m √ó Fin m)) : ‚Ñï) : ‚Ñù) := by
    exact_mod_cast hcard
  simpa using inv_pos.mpr hreal

theorem constructionProductWeight_nonneg {p : ‚Ñù} (hp0 : 0 ‚â§ p) (hp1 : p ‚â§ 1)
    (C : ConstructionData n m) :
    0 ‚â§ constructionProductWeight p C := by
  unfold constructionProductWeight
  exact mul_nonneg
    (mul_nonneg
      (constructionGraphBernoulliWeight_nonneg hp0 hp1 C.redBase)
      (constructionGraphBernoulliWeight_nonneg hp0 hp1 C.blueBase))
    (constructionEmbeddingUniformWeight_nonneg n m)

theorem constructionProductWeight_pos {p : ‚Ñù} (hp0 : 0 < p) (hp1 : p < 1)
    (C : ConstructionData n m) :
    0 < constructionProductWeight p C := by
  unfold constructionProductWeight
  exact mul_pos
    (mul_pos
      (constructionGraphBernoulliWeight_pos hp0 hp1 C.redBase)
      (constructionGraphBernoulliWeight_pos hp0 hp1 C.blueBase))
    (constructionEmbeddingUniformWeight_pos C)

theorem paperConstructionWeight_nonneg {Œ≤ : ‚Ñù}
    (hp0 : 0 ‚â§ Twobites.paperP Œ≤ n) (hp1 : Twobites.paperP Œ≤ n ‚â§ 1)
    (C : ConstructionData n m) :
    0 ‚â§ paperConstructionWeight Œ≤ n m C := by
  exact constructionProductWeight_nonneg hp0 hp1 C

theorem paperConstructionWeight_pos {Œ≤ : ‚Ñù}
    (hp0 : 0 < Twobites.paperP Œ≤ n) (hp1 : Twobites.paperP Œ≤ n < 1)
    (C : ConstructionData n m) :
    0 < paperConstructionWeight Œ≤ n m C := by
  exact constructionProductWeight_pos hp0 hp1 C

theorem constructionProductWeight_sum_univ_eq (p : ‚Ñù)
    (e : Fin n ‚Ü™ Fin m √ó Fin m) :
    (‚àë C : ConstructionData n m, constructionProductWeight p C) = ((1 - p) ^ m) ^ 2 := by
  classical
  let equivCD :
      ConstructionData n m ‚âÉ
        ((SimpleGraph (Fin m) √ó SimpleGraph (Fin m)) √ó (Fin n ‚Ü™ Fin m √ó Fin m)) :=
    { toFun := fun C => ((C.redBase, C.blueBase), C.embedding)
      invFun := fun t =>
        { redBase := t.1.1
          blueBase := t.1.2
          embedding := t.2 }
      left_inv := by
        intro C
        cases C
        rfl
      right_inv := by
        intro t
        cases t
        rfl }
  calc
    (‚àë C : ConstructionData n m, constructionProductWeight p C) =
        ‚àë t : ((SimpleGraph (Fin m) √ó SimpleGraph (Fin m)) √ó (Fin n ‚Ü™ Fin m √ó Fin m)),
          constructionProductWeight p
            { redBase := t.1.1
              blueBase := t.1.2
              embedding := t.2 } := by
          simpa [equivCD] using
            (Equiv.sum_comp equivCD.symm
              (fun C : ConstructionData n m => constructionProductWeight p C)).symm
    _ = ‚àë x : SimpleGraph (Fin m) √ó SimpleGraph (Fin m),
          ‚àë f : Fin n ‚Ü™ Fin m √ó Fin m,
            constructionProductWeight p
              { redBase := x.1
                blueBase := x.2
                embedding := f } := by
          rw [Fintype.sum_prod_type]
    _ = ‚àë x : SimpleGraph (Fin m) √ó SimpleGraph (Fin m),
          constructionGraphBernoulliWeight p x.1 *
            constructionGraphBernoulliWeight p x.2 := by
          refine Fintype.sum_congr
            (fun x : SimpleGraph (Fin m) √ó SimpleGraph (Fin m) =>
              ‚àë f : Fin n ‚Ü™ Fin m √ó Fin m,
                constructionProductWeight p
                  { redBase := x.1
                    blueBase := x.2
                    embedding := f })
            (fun x : SimpleGraph (Fin m) √ó SimpleGraph (Fin m) =>
              constructionGraphBernoulliWeight p x.1 *
                constructionGraphBernoulliWeight p x.2) ?_
          intro x
          calc
            (‚àë f : Fin n ‚Ü™ Fin m √ó Fin m,
                constructionProductWeight p
                  { redBase := x.1
                    blueBase := x.2
                    embedding := f }) =
                ‚àë f : Fin n ‚Ü™ Fin m √ó Fin m,
                  constructionGraphBernoulliWeight p x.1 *
                    (constructionGraphBernoulliWeight p x.2 *
                      constructionEmbeddingUniformWeight n m) := by
                  simp [constructionProductWeight, mul_assoc]
            _ = constructionGraphBernoulliWeight p x.1 *
                  (constructionGraphBernoulliWeight p x.2 *
                    ‚àë _ : Fin n ‚Ü™ Fin m √ó Fin m, constructionEmbeddingUniformWeight n m) := by
                  rw [‚Üê Finset.mul_sum, ‚Üê Finset.mul_sum]
            _ = constructionGraphBernoulliWeight p x.1 *
                  (constructionGraphBernoulliWeight p x.2 * 1) := by
                  rw [constructionEmbeddingUniformWeight_sum_univ_eq_one (n := n) (m := m) e]
            _ = constructionGraphBernoulliWeight p x.1 *
                  constructionGraphBernoulliWeight p x.2 := by
                  ring
    _ = (‚àë G : SimpleGraph (Fin m), constructionGraphBernoulliWeight p G) *
          ‚àë H : SimpleGraph (Fin m), constructionGraphBernoulliWeight p H := by
          rw [Fintype.sum_prod_type]
          symm
          simpa using
            (Finset.sum_mul_sum
              (Finset.univ : Finset (SimpleGraph (Fin m)))
              (Finset.univ : Finset (SimpleGraph (Fin m)))
              (fun G => constructionGraphBernoulliWeight p G)
              (fun H => constructionGraphBernoulliWeight p H))
    _ = (((1 - p) ^ m) * ((1 - p) ^ m)) := by
          have hgraphR :
              (‚àë G : SimpleGraph (Fin m), constructionGraphBernoulliWeight p G) = (1 - p) ^ m :=
            constructionGraphBernoulliWeight_sum_univ_eq (m := m) p
          have hgraphB :
              (‚àë H : SimpleGraph (Fin m), constructionGraphBernoulliWeight p H) = (1 - p) ^ m :=
            constructionGraphBernoulliWeight_sum_univ_eq (m := m) p
          simp [hgraphR]
    _ = ((1 - p) ^ m) ^ 2 := by
          rw [pow_two]

theorem paperConstructionMass_sampleSpace_eq {Œ≤ : ‚Ñù} {b : ‚Ñï}
    (hn : n ‚â§ m * b) (hb : b ‚â§ m) :
    constructionEventMass (paperConstructionWeight Œ≤ n m) (ConstructionData.sampleSpace n m) =
      ((1 - Twobites.paperP Œ≤ n) ^ m) ^ 2 := by
  simpa [constructionEventMass, ConstructionData.sampleSpace, paperConstructionWeight] using
    (constructionProductWeight_sum_univ_eq (n := n) (m := m)
      (p := Twobites.paperP Œ≤ n) (balancedBandEmbedding hn hb))

theorem constructionProductWeight_emptyBalancedConstructionData_eq
    {b : ‚Ñï} (hn : n ‚â§ m * b) (hb : b ‚â§ m) (p : ‚Ñù) :
    constructionProductWeight p (emptyBalancedConstructionData hn hb) =
      ((1 - p) ^ Fintype.card (Sym2 (Fin m))) *
        (((1 - p) ^ Fintype.card (Sym2 (Fin m))) * constructionEmbeddingUniformWeight n m) := by
  simp [constructionProductWeight, emptyBalancedConstructionData, mul_assoc]

theorem paperConstructionWeight_emptyBalancedConstructionData_eq
    {Œ≤ : ‚Ñù} {b : ‚Ñï} (hn : n ‚â§ m * b) (hb : b ‚â§ m) :
    paperConstructionWeight Œ≤ n m (emptyBalancedConstructionData hn hb) =
      ((1 - Twobites.paperP Œ≤ n) ^ Fintype.card (Sym2 (Fin m))) *
        (((1 - Twobites.paperP Œ≤ n) ^ Fintype.card (Sym2 (Fin m))) *
          constructionEmbeddingUniformWeight n m) := by
  simp [paperConstructionWeight, constructionProductWeight, emptyBalancedConstructionData,
    mul_assoc]

theorem constructionEventMass_nonneg {w : ConstructionData n m ‚Üí ‚Ñù}
    {E : Finset (ConstructionData n m)} (hwt : ‚àÄ C, 0 ‚â§ w C) :
    0 ‚â§ constructionEventMass w E := by
  unfold constructionEventMass
  exact Finset.sum_nonneg fun C _ => hwt C

theorem constructionEventMass_eq_sum_univ_indicator {w : ConstructionData n m ‚Üí ‚Ñù}
    (E : Finset (ConstructionData n m)) :
    constructionEventMass w E =
      ‚àë C : ConstructionData n m, if C ‚àà E then w C else 0 := by
  classical
  have hfilter :
      (Finset.univ : Finset (ConstructionData n m)).filter (fun C => C ‚àà E) = E := by
    ext C
    simp
  rw [constructionEventMass, ‚Üê hfilter, Finset.sum_filter]
  simp

theorem constructionEventMass_mono {w : ConstructionData n m ‚Üí ‚Ñù}
    {E F : Finset (ConstructionData n m)} (hEF : E ‚äÜ F)
    (hwt : ‚àÄ C, 0 ‚â§ w C) :
    constructionEventMass w E ‚â§ constructionEventMass w F := by
  unfold constructionEventMass
  exact Finset.sum_le_sum_of_subset_of_nonneg hEF fun C _ _ => hwt C

theorem constructionEventMass_union_le {w : ConstructionData n m ‚Üí ‚Ñù}
    (E F : Finset (ConstructionData n m)) (hwt : ‚àÄ C, 0 ‚â§ w C) :
    constructionEventMass w (E ‚à™ F) ‚â§ constructionEventMass w E + constructionEventMass w F := by
  have hunion : E ‚à™ F = E ‚à™ (F \ E) := by
    ext C
    by_cases hCE : C ‚àà E <;> by_cases hCF : C ‚àà F <;> simp [hCE, hCF]
  have hdisj : Disjoint E (F \ E) := by
    rw [Finset.disjoint_left]
    intro C hCE hCF
    exact (Finset.mem_sdiff.mp hCF).2 hCE
  rw [hunion]
  rw [constructionEventMass, Finset.sum_union hdisj, constructionEventMass]
  have hmono : constructionEventMass w (F \ E) ‚â§ constructionEventMass w F := by
    apply constructionEventMass_mono
    ¬∑ intro C hC
      exact (Finset.mem_sdiff.mp hC).1
    ¬∑ exact hwt
  simpa [add_comm, add_left_comm, add_assoc] using
    add_le_add_left hmono (constructionEventMass w E)

theorem constructionEventMass_biUnion_le {Œ± : Type*}
    {w : ConstructionData n m ‚Üí ‚Ñù} (s : Finset Œ±)
    (E : Œ± ‚Üí Finset (ConstructionData n m)) (hwt : ‚àÄ C, 0 ‚â§ w C) :
    constructionEventMass w (s.biUnion E) ‚â§
      ‚àë a ‚àà s, constructionEventMass w (E a) := by
  classical
  induction s using Finset.induction_on with
  | empty =>
      simp [constructionEventMass]
  | @insert a s ha hs =>
      rw [Finset.biUnion_insert]
      calc
        constructionEventMass w (E a ‚à™ s.biUnion E)
            ‚â§ constructionEventMass w (E a) + constructionEventMass w (s.biUnion E) :=
          constructionEventMass_union_le (w := w) (E := E a) (F := s.biUnion E) hwt
        _ ‚â§ constructionEventMass w (E a) + ‚àë b ‚àà s, constructionEventMass w (E b) :=
          by
            have hs' :
                constructionEventMass w (s.biUnion E) ‚â§ ‚àë b ‚àà s, constructionEventMass w (E b) :=
              hs
            simpa [add_comm, add_left_comm, add_assoc] using
              add_le_add_left hs' (constructionEventMass w (E a))
        _ = ‚àë b ‚àà insert a s, constructionEventMass w (E b) := by
          simp [ha]

theorem constructionEventMass_single_le_of_mem {w : ConstructionData n m ‚Üí ‚Ñù}
    {E : Finset (ConstructionData n m)} {C : ConstructionData n m}
    (hC : C ‚àà E) (hwt : ‚àÄ D, 0 ‚â§ w D) :
    w C ‚â§ constructionEventMass w E := by
  have hmono :
      constructionEventMass w ({C} : Finset (ConstructionData n m)) ‚â§ constructionEventMass w E :=
    constructionEventMass_mono (by
      intro D hD
      have hDC : D = C := by simpa using hD
      simpa [hDC] using hC) hwt
  simpa [constructionEventMass] using hmono

theorem constructionEventMass_pos_of_mem {w : ConstructionData n m ‚Üí ‚Ñù}
    {E : Finset (ConstructionData n m)} {C : ConstructionData n m}
    (hC : C ‚àà E) (hwt : ‚àÄ D, 0 ‚â§ w D) (hpos : 0 < w C) :
    0 < constructionEventMass w E :=
  lt_of_lt_of_le hpos (constructionEventMass_single_le_of_mem hC hwt)

theorem constructionEventMass_eq_sum_embeddings_graphWeights {p : ‚Ñù}
    (E : Finset (ConstructionData n m)) :
    constructionEventMass (constructionProductWeight p) E =
      ‚àë e : Fin n ‚Ü™ Fin m √ó Fin m,
        constructionEmbeddingUniformWeight n m *
          (‚àë x : SimpleGraph (Fin m) √ó SimpleGraph (Fin m),
            if ({ redBase := x.1
                  blueBase := x.2
                  embedding := e } : ConstructionData n m) ‚àà E then
              constructionGraphBernoulliWeight p x.1 *
                constructionGraphBernoulliWeight p x.2
            else
              0) := by
  classical
  let equivCD :
      ConstructionData n m ‚âÉ
        ((Fin n ‚Ü™ Fin m √ó Fin m) √ó (SimpleGraph (Fin m) √ó SimpleGraph (Fin m))) :=
    { toFun := fun C => (C.embedding, (C.redBase, C.blueBase))
      invFun := fun t =>
        { redBase := t.2.1
          blueBase := t.2.2
          embedding := t.1 }
      left_inv := by
        intro C
        cases C
        rfl
      right_inv := by
        intro t
        cases t
        rfl }
  let f :
      (Fin n ‚Ü™ Fin m √ó Fin m) ‚Üí
        (SimpleGraph (Fin m) √ó SimpleGraph (Fin m)) ‚Üí ‚Ñù :=
    fun e x =>
      if ({ redBase := x.1
            blueBase := x.2
            embedding := e } : ConstructionData n m) ‚àà E then
        constructionGraphBernoulliWeight p x.1 *
          constructionGraphBernoulliWeight p x.2
      else
        0
  calc
    constructionEventMass (constructionProductWeight p) E =
        ‚àë C : ConstructionData n m,
          if C ‚àà E then constructionProductWeight p C else 0 :=
      constructionEventMass_eq_sum_univ_indicator E
    _ =
        ‚àë t : ((Fin n ‚Ü™ Fin m √ó Fin m) √ó (SimpleGraph (Fin m) √ó SimpleGraph (Fin m))),
          if ({ redBase := t.2.1
                blueBase := t.2.2
                embedding := t.1 } : ConstructionData n m) ‚àà E then
            constructionProductWeight p
              { redBase := t.2.1
                blueBase := t.2.2
                embedding := t.1 }
          else
            0 := by
          simpa [equivCD] using
            (Equiv.sum_comp equivCD.symm
              (fun C : ConstructionData n m =>
                if C ‚àà E then constructionProductWeight p C else 0)).symm
    _ =
        ‚àë e : Fin n ‚Ü™ Fin m √ó Fin m,
          ‚àë x : SimpleGraph (Fin m) √ó SimpleGraph (Fin m),
            if ({ redBase := x.1
                  blueBase := x.2
                  embedding := e } : ConstructionData n m) ‚àà E then
              constructionProductWeight p
                { redBase := x.1
                  blueBase := x.2
                  embedding := e }
            else
              0 := by
          rw [Fintype.sum_prod_type]
    _ =
        ‚àë e : Fin n ‚Ü™ Fin m √ó Fin m,
          constructionEmbeddingUniformWeight n m *
            (‚àë x : SimpleGraph (Fin m) √ó SimpleGraph (Fin m), f e x) := by
          refine Fintype.sum_congr
            (fun e : Fin n ‚Ü™ Fin m √ó Fin m =>
              ‚àë x : SimpleGraph (Fin m) √ó SimpleGraph (Fin m),
                if ({ redBase := x.1
                      blueBase := x.2
                      embedding := e } : ConstructionData n m) ‚àà E then
                  constructionProductWeight p
                    { redBase := x.1
                      blueBase := x.2
                      embedding := e }
                else
                  0)
            (fun e : Fin n ‚Ü™ Fin m √ó Fin m =>
              constructionEmbeddingUniformWeight n m *
                (‚àë x : SimpleGraph (Fin m) √ó SimpleGraph (Fin m), f e x)) ?_
          intro e
          calc
            (‚àë x : SimpleGraph (Fin m) √ó SimpleGraph (Fin m),
                if ({ redBase := x.1
                      blueBase := x.2
                      embedding := e } : ConstructionData n m) ‚àà E then
                  constructionProductWeight p
                    { redBase := x.1
                      blueBase := x.2
                      embedding := e }
                else
                  0) =
                ‚àë x : SimpleGraph (Fin m) √ó SimpleGraph (Fin m),
                  constructionEmbeddingUniformWeight n m * f e x := by
                  refine Fintype.sum_congr
                    (fun x : SimpleGraph (Fin m) √ó SimpleGraph (Fin m) =>
                      if ({ redBase := x.1
                            blueBase := x.2
                            embedding := e } : ConstructionData n m) ‚àà E then
                        constructionProductWeight p
                          { redBase := x.1
                            blueBase := x.2
                            embedding := e }
                      else
                        0)
                    (fun x : SimpleGraph (Fin m) √ó SimpleGraph (Fin m) =>
                      constructionEmbeddingUniformWeight n m * f e x) ?_
                  intro x
                  let Cx : ConstructionData n m :=
                    { redBase := x.1
                      blueBase := x.2
                      embedding := e }
                  by_cases hx : Cx ‚àà E
                  ¬∑ simp [Cx, f, constructionProductWeight, hx, mul_comm]
                  ¬∑ simp [Cx, f, hx]
            _ =
                constructionEmbeddingUniformWeight n m *
                  (‚àë x : SimpleGraph (Fin m) √ó SimpleGraph (Fin m), f e x) := by
                  rw [‚Üê Finset.mul_sum]

/-- The empty-base balanced-band construction has red fibers of size at most the band width `b`. -/
theorem redFiber_card_le_of_emptyBalancedConstructionData {n m b : ‚Ñï}
    (hn : n ‚â§ m * b) (hb : b ‚â§ m) (r : Fin m) :
    ((emptyBalancedConstructionData hn hb).redFiber r).card ‚â§ b := by
  classical
  convert (Finset.card_le_card_of_injOn
    (s := (emptyBalancedConstructionData hn hb).redFiber r)
    (t := (Finset.univ : Finset (Fin b)))
    (f := fun v => (finProdFinEquiv.symm ((Fin.castLEEmb hn) v)).2) ?_ ?_) using 1
  ¬∑ simp
  ¬∑ intro v hv
    simp
  ¬∑ intro v hv w hw hEq
    have hv' : ((emptyBalancedConstructionData hn hb).embedding v).1 = r := by
      simpa [redFiber] using hv
    have hw' : ((emptyBalancedConstructionData hn hb).embedding w).1 = r := by
      simpa [redFiber] using hw
    have hfst :
        (finProdFinEquiv.symm ((Fin.castLEEmb hn) v)).1 =
          (finProdFinEquiv.symm ((Fin.castLEEmb hn) w)).1 := by
      simpa [emptyBalancedConstructionData, hv', hw'] using hv'.trans hw'.symm
    have hpair :
        finProdFinEquiv.symm ((Fin.castLEEmb hn) v) =
          finProdFinEquiv.symm ((Fin.castLEEmb hn) w) := by
      exact Prod.ext hfst hEq
    have heq : (Fin.castLEEmb hn) v = (Fin.castLEEmb hn) w := by
      simpa only [Equiv.apply_symm_apply] using congrArg finProdFinEquiv hpair
    exact (Fin.castLEEmb hn).injective heq

/-- The empty-base balanced-band construction has blue fibers of size at most the band width `b`. -/
theorem blueFiber_card_le_of_emptyBalancedConstructionData {n m b : ‚Ñï}
    (hn : n ‚â§ m * b) (hb : b ‚â§ m) (c : Fin m) :
    ((emptyBalancedConstructionData hn hb).blueFiber c).card ‚â§ b := by
  classical
  convert (Finset.card_le_card_of_injOn
    (s := (emptyBalancedConstructionData hn hb).blueFiber c)
    (t := (Finset.univ : Finset (Fin b)))
    (f := fun v => (finProdFinEquiv.symm ((Fin.castLEEmb hn) v)).2) ?_ ?_) using 1
  ¬∑ simp
  ¬∑ intro v hv
    simp
  ¬∑ intro v hv w hw hEq
    have hv' : ((emptyBalancedConstructionData hn hb).embedding v).2 = c := by
      simpa [blueFiber] using hv
    have hw' : ((emptyBalancedConstructionData hn hb).embedding w).2 = c := by
      simpa [blueFiber] using hw
    have hEqCast :
        Fin.castLE hb ((finProdFinEquiv.symm ((Fin.castLEEmb hn) v)).2) =
          Fin.castLE hb ((finProdFinEquiv.symm ((Fin.castLEEmb hn) w)).2) := by
      exact congrArg (Fin.castLE hb) hEq
    have hsum :
        (finProdFinEquiv.symm ((Fin.castLEEmb hn) v)).1 +
            Fin.castLE hb ((finProdFinEquiv.symm ((Fin.castLEEmb hn) v)).2) =
          (finProdFinEquiv.symm ((Fin.castLEEmb hn) w)).1 +
            Fin.castLE hb ((finProdFinEquiv.symm ((Fin.castLEEmb hn) w)).2) := by
      simpa [emptyBalancedConstructionData] using hv'.trans hw'.symm
    have hfst :
        (finProdFinEquiv.symm ((Fin.castLEEmb hn) v)).1 =
          (finProdFinEquiv.symm ((Fin.castLEEmb hn) w)).1 := by
      rw [hEqCast] at hsum
      exact add_right_cancel hsum
    have hpair :
        finProdFinEquiv.symm ((Fin.castLEEmb hn) v) =
          finProdFinEquiv.symm ((Fin.castLEEmb hn) w) := by
      exact Prod.ext hfst hEq
    have heq : (Fin.castLEEmb hn) v = (Fin.castLEEmb hn) w := by
      simpa only [Equiv.apply_symm_apply] using congrArg finProdFinEquiv hpair
    exact (Fin.castLEEmb hn).injective heq

/-- Empty base graphs automatically satisfy all projection and codegree clauses of `GoodEventD`;
the balanced-band embedding supplies the needed fiber bounds. -/
theorem goodEventD_of_emptyBalancedConstructionData
    {n m b fiberBound degreeBound codegreeBound projCodegreeBound : ‚Ñï}
    (hn : n ‚â§ m * b) (hb : b ‚â§ m) (hfb : b ‚â§ fiberBound) :
    GoodEventD (emptyBalancedConstructionData hn hb) fiberBound degreeBound codegreeBound
      projCodegreeBound := by
  classical
  refine {
    redFiberBound := ?_,
    blueFiberBound := ?_,
    redProjectionBound := ?_,
    blueProjectionBound := ?_,
    xInterBound := ?_,
    blueProjectionInterBound := ?_,
    redProjectionInterBound := ?_ }
  ¬∑ intro r
    exact (redFiber_card_le_of_emptyBalancedConstructionData hn hb r).trans hfb
  ¬∑ intro c
    exact (blueFiber_card_le_of_emptyBalancedConstructionData hn hb c).trans hfb
  ¬∑ intro r
    simp [redProjectionImage, X, emptyBalancedConstructionData]
  ¬∑ intro b'
    simp [blueProjectionImage, X, emptyBalancedConstructionData]
  ¬∑ intro x y hxy
    cases x <;> cases y <;> simp [X, emptyBalancedConstructionData]
  ¬∑ intro r r' hrr'
    simp [blueProjectionImage, X, emptyBalancedConstructionData]
  ¬∑ intro b1 b2 hbb
    simp [redProjectionImage, X, emptyBalancedConstructionData]

theorem constructionEventMass_goodEventDSet_ge_emptyBalancedConstructionWeight
    {w : ConstructionData n m ‚Üí ‚Ñù} {b fiberBound degreeBound codegreeBound projCodegreeBound : ‚Ñï}
    (hn : n ‚â§ m * b) (hb : b ‚â§ m) (hfb : b ‚â§ fiberBound) (hwt : ‚àÄ C, 0 ‚â§ w C) :
    w (emptyBalancedConstructionData hn hb) ‚â§
      constructionEventMass w (goodEventDSet n m fiberBound degreeBound codegreeBound
        projCodegreeBound) := by
  have hmem :
      emptyBalancedConstructionData hn hb ‚àà
        goodEventDSet n m fiberBound degreeBound codegreeBound projCodegreeBound := by
    rw [mem_goodEventDSet_iff]
    exact goodEventD_of_emptyBalancedConstructionData hn hb hfb
  exact constructionEventMass_single_le_of_mem hmem hwt

theorem constructionEventMass_goodEventDSet_pos_of_emptyBalancedConstructionData
    {w : ConstructionData n m ‚Üí ‚Ñù} {b fiberBound degreeBound codegreeBound projCodegreeBound : ‚Ñï}
    (hn : n ‚â§ m * b) (hb : b ‚â§ m) (hfb : b ‚â§ fiberBound) (hwt : ‚àÄ C, 0 ‚â§ w C)
    (hpos : 0 < w (emptyBalancedConstructionData hn hb)) :
    0 < constructionEventMass w (goodEventDSet n m fiberBound degreeBound codegreeBound
      projCodegreeBound) := by
  have hmem :
      emptyBalancedConstructionData hn hb ‚àà
        goodEventDSet n m fiberBound degreeBound codegreeBound projCodegreeBound := by
    rw [mem_goodEventDSet_iff]
    exact goodEventD_of_emptyBalancedConstructionData hn hb hfb
  exact constructionEventMass_pos_of_mem hmem hwt hpos

theorem paperConstructionMass_goodEventDSet_pos_of_emptyBalancedConstructionData
    {Œ≤ : ‚Ñù} {n m b fiberBound degreeBound codegreeBound projCodegreeBound : ‚Ñï}
    (hp0 : 0 < Twobites.paperP Œ≤ n) (hp1 : Twobites.paperP Œ≤ n < 1)
    (hn : n ‚â§ m * b) (hb : b ‚â§ m) (hfb : b ‚â§ fiberBound) :
    0 < constructionEventMass (paperConstructionWeight Œ≤ n m)
      (goodEventDSet n m fiberBound degreeBound codegreeBound projCodegreeBound) := by
  apply constructionEventMass_goodEventDSet_pos_of_emptyBalancedConstructionData
    (hn := hn) (hb := hb) (hfb := hfb)
  ¬∑ intro C
    exact paperConstructionWeight_nonneg hp0.le hp1.le C
  ¬∑ exact paperConstructionWeight_pos hp0 hp1 (emptyBalancedConstructionData hn hb)

theorem paperConstructionMass_goodEventDSet_ge_emptyBalancedConstructionWeight_explicit
    {Œ≤ : ‚Ñù} {n m b fiberBound degreeBound codegreeBound projCodegreeBound : ‚Ñï}
    (hp0 : 0 ‚â§ Twobites.paperP Œ≤ n) (hp1 : Twobites.paperP Œ≤ n ‚â§ 1)
    (hn : n ‚â§ m * b) (hb : b ‚â§ m) (hfb : b ‚â§ fiberBound) :
    ((1 - Twobites.paperP Œ≤ n) ^ Fintype.card (Sym2 (Fin m))) *
        (((1 - Twobites.paperP Œ≤ n) ^ Fintype.card (Sym2 (Fin m))) *
          constructionEmbeddingUniformWeight n m) ‚â§
      constructionEventMass (paperConstructionWeight Œ≤ n m)
        (goodEventDSet n m fiberBound degreeBound codegreeBound projCodegreeBound) := by
  have hbound :
      paperConstructionWeight Œ≤ n m (emptyBalancedConstructionData hn hb) ‚â§
        constructionEventMass (paperConstructionWeight Œ≤ n m)
          (goodEventDSet n m fiberBound degreeBound codegreeBound projCodegreeBound) :=
    constructionEventMass_goodEventDSet_ge_emptyBalancedConstructionWeight
      (hn := hn) (hb := hb) (hfb := hfb) (w := paperConstructionWeight Œ≤ n m) (by
        intro C
        exact paperConstructionWeight_nonneg hp0 hp1 C)
  simpa [paperConstructionWeight_emptyBalancedConstructionData_eq
    (Œ≤ := Œ≤) (hn := hn) (hb := hb)] using hbound

/-- Paper Section 3's huge part `H_I`. -/
def HPart (C : ConstructionData n m) (I : Finset (Fin n)) : Finset (BaseVertex m) := by
  classical
  exact Finset.univ.filter fun x =>
    Twobites.paperT1 n < (C.xCard I x : ‚Ñù) ‚àß (C.xCard I x : ‚Ñù) ‚â§ (I.card : ‚Ñù)

/-- Paper Section 3's large part `L_I`. -/
def LPart (C : ConstructionData n m) (I : Finset (Fin n)) (Œµ : ‚Ñù) : Finset (BaseVertex m) := by
  classical
  exact Finset.univ.filter fun x =>
    Twobites.paperT2 Œµ n < (C.xCard I x : ‚Ñù) ‚àß (C.xCard I x : ‚Ñù) ‚â§ Twobites.paperT1 n

/-- Paper Section 3's medium part `M_I`. -/
def MPart (C : ConstructionData n m) (I : Finset (Fin n)) (Œµ : ‚Ñù) : Finset (BaseVertex m) := by
  classical
  exact Finset.univ.filter fun x =>
    Twobites.paperT3 Œµ n < (C.xCard I x : ‚Ñù) ‚àß (C.xCard I x : ‚Ñù) ‚â§ Twobites.paperT2 Œµ n

/-- Paper Section 3's small part `S_I`. -/
def SPart (C : ConstructionData n m) (I : Finset (Fin n)) (Œµ : ‚Ñù) : Finset (BaseVertex m) := by
  classical
  exact Finset.univ.filter fun x =>
    (C.xCard I x : ‚Ñù) ‚â§ Twobites.paperT3 Œµ n

/-- The total weight `‚àë_{v ‚àà A} |X_v(I)|` of a selected part `A ‚äÜ V_R ‚à™ V_B`. -/
def partWeight (C : ConstructionData n m) (I : Finset (Fin n)) (A : Finset (BaseVertex m)) : ‚Ñï :=
  ‚àë x ‚àà A, C.xCard I x

/-- The raw sum `‚àë_{v ‚àà A} (|X_v(I)| choose 2)` that upper-bounds the contribution of closed pairs
from a part before inclusion-exclusion. -/
def partPairCount (C : ConstructionData n m) (I : Finset (Fin n))
    (A : Finset (BaseVertex m)) : ‚Ñï :=
  ‚àë x ‚àà A, (C.xCard I x).choose 2

/-- The total red-projection weight `‚àë_{v ‚àà A} |œÄ_R(X_v(I))|`. -/
def redProjectionWeight (C : ConstructionData n m) (I : Finset (Fin n))
    (A : Finset (BaseVertex m)) : ‚Ñï :=
  ‚àë x ‚àà A, (C.redProjectionImage I x).card

/-- The huge-case red self-contribution `‚àë_{v ‚àà A} (|œÄ_R(X_v(I))| choose 2)`. -/
def redProjectionPairCount (C : ConstructionData n m) (I : Finset (Fin n))
    (A : Finset (BaseVertex m)) : ‚Ñï :=
  ‚àë x ‚àà A, ((C.redProjectionImage I x).card).choose 2

/-- The total blue-projection weight `‚àë_{v ‚àà A} |œÄ_B(X_v(I))|`. -/
def blueProjectionWeight (C : ConstructionData n m) (I : Finset (Fin n))
    (A : Finset (BaseVertex m)) : ‚Ñï :=
  ‚àë x ‚àà A, (C.blueProjectionImage I x).card

/-- The huge-case blue self-contribution `‚àë_{v ‚àà A} (|œÄ_B(X_v(I))| choose 2)`. -/
def blueProjectionPairCount (C : ConstructionData n m) (I : Finset (Fin n))
    (A : Finset (BaseVertex m)) : ‚Ñï :=
  ‚àë x ‚àà A, ((C.blueProjectionImage I x).card).choose 2

/-- The union `‚ãÉ_{v ‚àà A} œÄ_R(X_v(I))` that appears in the huge-case projection bounds. -/
def redProjectionUnion (C : ConstructionData n m) (I : Finset (Fin n))
    (A : Finset (BaseVertex m)) : Finset (Fin m) :=
  A.biUnion fun x => C.redProjectionImage I x

/-- The union `‚ãÉ_{v ‚àà A} œÄ_B(X_v(I))` that appears in the huge-case projection bounds. -/
def blueProjectionUnion (C : ConstructionData n m) (I : Finset (Fin n))
    (A : Finset (BaseVertex m)) : Finset (Fin m) :=
  A.biUnion fun x => C.blueProjectionImage I x

/-- The Section 4 base-vertex image `œÄ_R(I) ‚à™ œÄ_B(I)` inside `V_R ‚à™ V_B`. -/
def baseImage (C : ConstructionData n m) (I : Finset (Fin n)) : Finset (BaseVertex m) := by
  classical
  exact Finset.univ.filter fun x =>
    match x with
    | Sum.inl r => r ‚àà C.redImage I
    | Sum.inr b => b ‚àà C.blueImage I

/-- The fiber `F(v)` from Section 4, expressed uniformly on `V_R ‚à™ V_B`. -/
def baseFiber (C : ConstructionData n m) : BaseVertex m ‚Üí Finset (Fin n)
  | Sum.inl r => C.redFiber r
  | Sum.inr b => C.blueFiber b

/-- The base-graph neighborhood `N(v)` from Section 4, expressed uniformly on `V_R ‚à™ V_B`. -/
def baseNeighborSet (C : ConstructionData n m) : BaseVertex m ‚Üí Finset (BaseVertex m) := by
  classical
  intro x
  cases x with
  | inl r =>
      exact (Finset.univ.filter fun r' : Fin m => C.redBase.Adj r r').image Sum.inl
  | inr b =>
      exact (Finset.univ.filter fun b' : Fin m => C.blueBase.Adj b b').image Sum.inr

/-- Section 4's first revealed set `F_0 = (V_R ‚à™ V_B) \setminus (œÄ_R(I) ‚à™ œÄ_B(I))`. -/
def section4F0 (C : ConstructionData n m) (I : Finset (Fin n)) : Finset (BaseVertex m) := by
  classical
  exact Finset.univ \ C.baseImage I

/-- Section 4's second revealed set `F_1 = {v ‚àà œÄ_R(I) ‚à™ œÄ_B(I) : |F(v) ‚à© I| > log n}`. -/
def section4F1 (C : ConstructionData n m) (I : Finset (Fin n)) : Finset (BaseVertex m) := by
  classical
  exact (C.baseImage I).filter fun x =>
    Real.log (n : ‚Ñù) < (((C.baseFiber x ‚à© I).card : ‚Ñï) : ‚Ñù)

/-- Section 4's third revealed set `F_2 = {v ‚àà œÄ_R(I) ‚à™ œÄ_B(I) : |N(v) ‚à© F_1| > t_2 / log n}`. -/
def section4F2 (C : ConstructionData n m) (I : Finset (Fin n)) (Œµ : ‚Ñù) :
    Finset (BaseVertex m) := by
  classical
  exact (C.baseImage I).filter fun x =>
    Twobites.paperT2 Œµ n / Real.log (n : ‚Ñù) <
      (((C.baseNeighborSet x ‚à© C.section4F1 I).card : ‚Ñï) : ‚Ñù)

/-- The total Section 4 revealed base-vertex set `F = F_0 ‚à™ F_1 ‚à™ F_2`. -/
def section4F (C : ConstructionData n m) (I : Finset (Fin n)) (Œµ : ‚Ñù) :
    Finset (BaseVertex m) :=
  C.section4F0 I ‚à™ C.section4F1 I ‚à™ C.section4F2 I Œµ

/-- An ordered overcount of the same-color base-image pairs exposed when every vertex of `A` is
queried against `B`. This is the finite counting object used for the Section 4 reveal budget. -/
def revealedBaseArcSet (A B : Finset (BaseVertex m)) : Finset (BaseVertex m √ó BaseVertex m) := by
  classical
  exact
    (((A.filter IsRedBaseVertex).product (B.filter IsRedBaseVertex)).filter fun p => p.1 ‚âÝ p.2) ‚à™
      (((A.filter IsBlueBaseVertex).product (B.filter IsBlueBaseVertex)).filter
        fun p => p.1 ‚âÝ p.2)

/-- The Section 4 counting argument only needs an overcount, so we reuse the ordered arc set as the
pair-counting object. -/
def revealedBasePairSet (A B : Finset (BaseVertex m)) : Finset (BaseVertex m √ó BaseVertex m) := by
  exact revealedBaseArcSet A B

/-- Canonical red pairs inside `œÄ_R(I)`, counted with the order `r < r'`. -/
def redBasePairSet (C : ConstructionData n m) (I : Finset (Fin n)) :
    Finset (Fin m √ó Fin m) := by
  classical
  exact ((C.redImage I).product (C.redImage I)).filter fun p => p.1 < p.2

/-- Canonical blue pairs inside `œÄ_B(I)`, counted with the order `b < b'`. -/
def blueBasePairSet (C : ConstructionData n m) (I : Finset (Fin n)) :
    Finset (Fin m √ó Fin m) := by
  classical
  exact ((C.blueImage I).product (C.blueImage I)).filter fun p => p.1 < p.2

/-- The paper's same-color pair object inside `œÄ_R(I) ‚à™ œÄ_B(I)`, before distinguishing edges from
non-edges. -/
def basePairSet (C : ConstructionData n m) (I : Finset (Fin n)) :
    Finset (BaseVertex m √ó BaseVertex m) := by
  classical
  exact
    ((C.redBasePairSet I).image fun p => (Sum.inl p.1, Sum.inl p.2)) ‚à™
      ((C.blueBasePairSet I).image fun p => (Sum.inr p.1, Sum.inr p.2))

/-- Section 4's ordered overcount of revealed pairs coming from the queried vertices `A`. -/
def section4RevealArcSet (C : ConstructionData n m) (I : Finset (Fin n))
    (A : Finset (BaseVertex m)) : Finset (BaseVertex m √ó BaseVertex m) :=
  revealedBaseArcSet A (C.baseImage I)

/-- Section 4's finite same-color reveal-counting object contributed by the queried vertices `A`.
It is an overcount rather than a deduplicated unordered-pair set, which is enough for the paper's
budget estimate. -/
def section4RevealPairSet (C : ConstructionData n m) (I : Finset (Fin n))
    (A : Finset (BaseVertex m)) : Finset (BaseVertex m √ó BaseVertex m) :=
  revealedBasePairSet A (C.baseImage I)

/-- Canonical red open pairs inside `œÄ_R(I)`, counted with the order `r < r'`. -/
def redBaseOpenPairSet (C : ConstructionData n m) (I : Finset (Fin n)) :
    Finset (Fin m √ó Fin m) := by
  classical
  exact ((C.redImage I).product (C.redImage I)).filter fun p =>
    p.1 < p.2 ‚àß ¬¨ C.redBase.Adj p.1 p.2

/-- Canonical blue open pairs inside `œÄ_B(I)`, counted with the order `b < b'`. -/
def blueBaseOpenPairSet (C : ConstructionData n m) (I : Finset (Fin n)) :
    Finset (Fin m √ó Fin m) := by
  classical
  exact ((C.blueImage I).product (C.blueImage I)).filter fun p =>
    p.1 < p.2 ‚àß ¬¨ C.blueBase.Adj p.1 p.2

/-- Canonical red closed pairs inside `œÄ_R(I)`, counted with the order `r < r'`. -/
def redBaseClosedPairSet (C : ConstructionData n m) (I : Finset (Fin n)) :
    Finset (Fin m √ó Fin m) := by
  classical
  exact (C.redBasePairSet I).filter fun p => C.redBase.Adj p.1 p.2

/-- Canonical blue closed pairs inside `œÄ_B(I)`, counted with the order `b < b'`. -/
def blueBaseClosedPairSet (C : ConstructionData n m) (I : Finset (Fin n)) :
    Finset (Fin m √ó Fin m) := by
  classical
  exact (C.blueBasePairSet I).filter fun p => C.blueBase.Adj p.1 p.2

/-- The paper's open pairs inside `œÄ_R(I) ‚à™ œÄ_B(I)`, represented as canonical same-color base
pairs. -/
def baseOpenPairSet (C : ConstructionData n m) (I : Finset (Fin n)) :
    Finset (BaseVertex m √ó BaseVertex m) := by
  classical
  exact
    ((C.redBaseOpenPairSet I).image fun p => (Sum.inl p.1, Sum.inl p.2)) ‚à™
      ((C.blueBaseOpenPairSet I).image fun p => (Sum.inr p.1, Sum.inr p.2))

/-- Those base open pairs already revealed by querying vertices of `A`. -/
def revealedBaseOpenPairSet (C : ConstructionData n m) (I : Finset (Fin n))
    (A : Finset (BaseVertex m)) : Finset (BaseVertex m √ó BaseVertex m) := by
  classical
  exact (C.baseOpenPairSet I).filter fun p => p.1 ‚àà A ‚à® p.2 ‚àà A

/-- Those base open pairs still unrevealed after querying vertices of `A`. -/
def unrevealedBaseOpenPairSet (C : ConstructionData n m) (I : Finset (Fin n))
    (A : Finset (BaseVertex m)) : Finset (BaseVertex m √ó BaseVertex m) := by
  classical
  exact (C.baseOpenPairSet I).filter fun p => p.1 ‚àâ A ‚àß p.2 ‚àâ A

/-- The paper's unrevealed same-color pair object after querying the vertices of `A`. -/
def unrevealedBasePairSet (C : ConstructionData n m) (I : Finset (Fin n))
    (A : Finset (BaseVertex m)) : Finset (BaseVertex m √ó BaseVertex m) := by
  classical
  exact (C.basePairSet I).filter fun p => p.1 ‚àâ A ‚àß p.2 ‚àâ A

/-- Canonical unrevealed red pairs after querying `A`, matching the red part of the paper's
`E_I`. -/
def unrevealedRedBasePairSet (C : ConstructionData n m) (I : Finset (Fin n))
    (A : Finset (BaseVertex m)) : Finset (Fin m √ó Fin m) := by
  classical
  exact (C.redBasePairSet I).filter fun p => Sum.inl p.1 ‚àâ A ‚àß Sum.inl p.2 ‚àâ A

/-- Canonical unrevealed blue pairs after querying `A`, matching the blue part of the paper's
`E_I`. -/
def unrevealedBlueBasePairSet (C : ConstructionData n m) (I : Finset (Fin n))
    (A : Finset (BaseVertex m)) : Finset (Fin m √ó Fin m) := by
  classical
  exact (C.blueBasePairSet I).filter fun p => Sum.inr p.1 ‚àâ A ‚àß Sum.inr p.2 ‚àâ A

/-- The red same-color `ClosedPairPlus` contribution `‚ãÉ_i {N^+(r_i) choose 2}` on canonical red
pairs. -/
def redBaseClosedPlusPair (C : ConstructionData n m) (I : Finset (Fin n)) (p : Fin m √ó Fin m) :
    Prop :=
  ‚àÉ r ‚àà C.redImage I,
    C.redBase.Adj r p.1 ‚àß C.redBase.Adj r p.2 ‚àß r < p.1 ‚àß r < p.2

/-- The blue same-color `ClosedPairPlus` contribution `‚ãÉ_i {N^+(b_i) choose 2}` on canonical blue
pairs. -/
def blueBaseClosedPlusPair (C : ConstructionData n m) (I : Finset (Fin n)) (p : Fin m √ó Fin m) :
    Prop :=
  ‚àÉ b ‚àà C.blueImage I,
    C.blueBase.Adj b p.1 ‚àß C.blueBase.Adj b p.2 ‚àß b < p.1 ‚àß b < p.2

/-- The paper's `T_R`: unrevealed red pairs after removing the red same-color `ClosedPairPlus`
part. -/
def section4TRedPairSet (C : ConstructionData n m) (I : Finset (Fin n))
    (A : Finset (BaseVertex m)) : Finset (Fin m √ó Fin m) := by
  classical
  exact (C.unrevealedRedBasePairSet I A).filter fun p => ¬¨ C.redBaseClosedPlusPair I p

/-- The paper's `T_B`: unrevealed blue pairs after removing the blue same-color `ClosedPairPlus`
part. -/
def section4TBluePairSet (C : ConstructionData n m) (I : Finset (Fin n))
    (A : Finset (BaseVertex m)) : Finset (Fin m √ó Fin m) := by
  classical
  exact (C.unrevealedBlueBasePairSet I A).filter fun p => ¬¨ C.blueBaseClosedPlusPair I p

/-- The combined same-color `ClosedPairPlus` predicate on canonical base pairs. -/
def sameColorClosedPlusBasePair (C : ConstructionData n m) (I : Finset (Fin n))
    (p : BaseVertex m √ó BaseVertex m) : Prop :=
  match p.1, p.2 with
  | Sum.inl r, Sum.inl r' => C.redBaseClosedPlusPair I (r, r')
  | Sum.inr b, Sum.inr b' => C.blueBaseClosedPlusPair I (b, b')
  | _, _ => False

/-- The combined `T_I = T_R ‚à™ T_B` object used in the proof of `lem:RISI`. -/
def section4TPairSet (C : ConstructionData n m) (I : Finset (Fin n))
    (A : Finset (BaseVertex m)) : Finset (BaseVertex m √ó BaseVertex m) := by
  classical
  exact (C.unrevealedBasePairSet I A).filter fun p => ¬¨ C.sameColorClosedPlusBasePair I p

/-- The unrevealed same-color pairs removed from `E_I` by the same-color `ClosedPairPlus`
contribution before defining `T_R ‚à™ T_B`. -/
def sameColorClosedPlusBasePairSet (C : ConstructionData n m) (I : Finset (Fin n))
    (A : Finset (BaseVertex m)) : Finset (BaseVertex m √ó BaseVertex m) := by
  classical
  exact (C.unrevealedBasePairSet I A).filter fun p => C.sameColorClosedPlusBasePair I p

/-- Canonical red pairs removed by the red same-color `ClosedPairPlus` contribution. -/
def redBaseClosedPlusPairSet (C : ConstructionData n m) (I : Finset (Fin n)) :
    Finset (Fin m √ó Fin m) := by
  classical
  exact (C.redBasePairSet I).filter fun p => C.redBaseClosedPlusPair I p

/-- Canonical blue pairs removed by the blue same-color `ClosedPairPlus` contribution. -/
def blueBaseClosedPlusPairSet (C : ConstructionData n m) (I : Finset (Fin n)) :
    Finset (Fin m √ó Fin m) := by
  classical
  exact (C.blueBasePairSet I).filter fun p => C.blueBaseClosedPlusPair I p

/-- The paper's `U_R = T_R ‚à© E(G_R)` on canonical red base pairs. -/
def section4URedPairSet (C : ConstructionData n m) (I : Finset (Fin n))
    (A : Finset (BaseVertex m)) : Finset (Fin m √ó Fin m) := by
  classical
  exact (C.section4TRedPairSet I A).filter fun p => C.redBase.Adj p.1 p.2

/-- The paper's `U_B = T_B ‚à© E(G_B)` on canonical blue base pairs. -/
def section4UBluePairSet (C : ConstructionData n m) (I : Finset (Fin n))
    (A : Finset (BaseVertex m)) : Finset (Fin m √ó Fin m) := by
  classical
  exact (C.section4TBluePairSet I A).filter fun p => C.blueBase.Adj p.1 p.2

/-- The combined `U_R ‚à™ U_B` object on base vertices. -/
def section4UPairSet (C : ConstructionData n m) (I : Finset (Fin n))
    (A : Finset (BaseVertex m)) : Finset (BaseVertex m √ó BaseVertex m) := by
  classical
  exact
    ((C.section4URedPairSet I A).image fun p => (Sum.inl p.1, Sum.inl p.2)) ‚à™
      ((C.section4UBluePairSet I A).image fun p => (Sum.inr p.1, Sum.inr p.2))

/-- The opposite-color red witness pool
`‚ãÉ_{b ‚àâ A} œÄ_R({X_b(I) choose 2})`, represented as unordered red pairs. -/
def redOppositeWitnessBiUnion (C : ConstructionData n m) (I : Finset (Fin n))
    (A : Finset (BaseVertex m)) : Finset (Sym2 (Fin m)) :=
  (Finset.univ.filter fun b : Fin m => Sum.inr b ‚àâ A).biUnion fun b =>
    (C.redProjectionImage I (Sum.inr b)).offDiag.image Sym2.mk

/-- The opposite-color blue witness pool
`‚ãÉ_{r ‚àâ A} œÄ_B({X_r(I) choose 2})`, represented as unordered blue pairs. -/
def blueOppositeWitnessBiUnion (C : ConstructionData n m) (I : Finset (Fin n))
    (A : Finset (BaseVertex m)) : Finset (Sym2 (Fin m)) :=
  (Finset.univ.filter fun r : Fin m => Sum.inl r ‚àâ A).biUnion fun r =>
    (C.blueProjectionImage I (Sum.inl r)).offDiag.image Sym2.mk

/-- The monochromatic red witness pool `‚ãÉ_{r ‚àà V_R} œÄ_R({X_r(I) choose 2})`, represented as
unordered red pairs. -/
def redMonochromaticWitnessBiUnion (C : ConstructionData n m) (I : Finset (Fin n)) :
    Finset (Sym2 (Fin m)) :=
  (Finset.univ : Finset (Fin m)).biUnion fun r =>
    (C.redProjectionImage I (Sum.inl r)).offDiag.image Sym2.mk

/-- The monochromatic blue witness pool `‚ãÉ_{b ‚àà V_B} œÄ_B({X_b(I) choose 2})`, represented as
unordered blue pairs. -/
def blueMonochromaticWitnessBiUnion (C : ConstructionData n m) (I : Finset (Fin n)) :
    Finset (Sym2 (Fin m)) :=
  (Finset.univ : Finset (Fin m)).biUnion fun b =>
    (C.blueProjectionImage I (Sum.inr b)).offDiag.image Sym2.mk

/-- The red projection-pair witness pool `‚ãÉ_{x ‚àà A} œÄ_R({X_x(I) choose 2})`, represented as
unordered red pairs. -/
def redProjectionPairBiUnion (C : ConstructionData n m) (I : Finset (Fin n))
    (A : Finset (BaseVertex m)) : Finset (Sym2 (Fin m)) :=
  A.biUnion fun x => (C.redProjectionImage I x).offDiag.image Sym2.mk

/-- The blue projection-pair witness pool `‚ãÉ_{x ‚àà A} œÄ_B({X_x(I) choose 2})`, represented as
unordered blue pairs. -/
def blueProjectionPairBiUnion (C : ConstructionData n m) (I : Finset (Fin n))
    (A : Finset (BaseVertex m)) : Finset (Sym2 (Fin m)) :=
  A.biUnion fun x => (C.blueProjectionImage I x).offDiag.image Sym2.mk

/-- The paper's closed-pair predicate `C(I)`, expressed on ordered pairs of distinct vertices of
`I`. -/
def ClosedPair (C : ConstructionData n m) (I : Finset (Fin n)) (v w : Fin n) : Prop :=
  v ‚àà I ‚àß w ‚àà I ‚àß v ‚âÝ w ‚àß ‚àÉ x : BaseVertex m, v ‚àà C.X I x ‚àß w ‚àà C.X I x

/-- The paper's `C^+(I)` predicate, built from the forward-neighborhood sets `X_v^+(I)`. -/
def ClosedPairPlus (C : ConstructionData n m) (I : Finset (Fin n)) (v w : Fin n) : Prop :=
  v ‚àà I ‚àß w ‚àà I ‚àß v ‚âÝ w ‚àß ‚àÉ x : BaseVertex m, v ‚àà C.XPlus I x ‚àß w ‚àà C.XPlus I x

/-- The closed-pair predicate restricted to a chosen part of `V_R ‚à™ V_B`, matching the paper's
unions over `H_I`, `L_I`, `M_I`, and `S_I`. -/
def ClosedPairOn (C : ConstructionData n m) (I : Finset (Fin n)) (A : Finset (BaseVertex m))
    (v w : Fin n) : Prop :=
  v ‚àà I ‚àß w ‚àà I ‚àß v ‚âÝ w ‚àß ‚àÉ x ‚àà A, v ‚àà C.X I x ‚àß w ‚àà C.X I x

/-- The forward-neighborhood version of `ClosedPairOn`. -/
def ClosedPairPlusOn (C : ConstructionData n m) (I : Finset (Fin n)) (A : Finset (BaseVertex m))
    (v w : Fin n) : Prop :=
  v ‚àà I ‚àß w ‚àà I ‚àß v ‚âÝ w ‚àß ‚àÉ x ‚àà A, v ‚àà C.XPlus I x ‚àß w ‚àà C.XPlus I x

/-- The open-pair predicate after only revealing closed pairs witnessed inside `A ‚äÜ V_R ‚à™ V_B`. -/
def OpenPairOn (C : ConstructionData n m) (I : Finset (Fin n)) (A : Finset (BaseVertex m))
    (v w : Fin n) : Prop :=
  v ‚àà I ‚àß w ‚àà I ‚àß v ‚âÝ w ‚àß ¬¨ C.ClosedPairOn I A v w

/-- The forward-neighborhood analogue of `OpenPairOn`. -/
def OpenPairPlusOn (C : ConstructionData n m) (I : Finset (Fin n)) (A : Finset (BaseVertex m))
    (v w : Fin n) : Prop :=
  v ‚àà I ‚àß w ‚àà I ‚àß v ‚âÝ w ‚àß ¬¨ C.ClosedPairPlusOn I A v w

/-- The paper's open-pair predicate `O(I)`. -/
def OpenPair (C : ConstructionData n m) (I : Finset (Fin n)) (v w : Fin n) : Prop :=
  v ‚àà I ‚àß w ‚àà I ‚àß v ‚âÝ w ‚àß ¬¨ C.ClosedPair I v w

/-- The paper's `O^+(I)` predicate. -/
def OpenPairPlus (C : ConstructionData n m) (I : Finset (Fin n)) (v w : Fin n) : Prop :=
  v ‚àà I ‚àß w ‚àà I ‚àß v ‚âÝ w ‚àß ¬¨ C.ClosedPairPlus I v w

/-- The exact conditioned `U_R` object used in the Section 4 probability estimate: canonical red
base edges whose lifted realizations remain open with respect to `A` and are not
`ClosedPairPlus`. -/
def section4URedCondPairSet (C : ConstructionData n m) (I : Finset (Fin n))
    (A : Finset (BaseVertex m)) : Finset (Fin m √ó Fin m) := by
  classical
  exact (C.section4URedPairSet I A).filter fun p =>
    ‚àÉ v ‚àà I, ‚àÉ w ‚àà I,
      C.redProj v = p.1 ‚àß C.redProj w = p.2 ‚àß
        v ‚âÝ w ‚àß C.OpenPairOn I A v w ‚àß C.OpenPairPlus I v w

/-- The exact conditioned `U_B` object used in the Section 4 probability estimate: canonical blue
base edges whose lifted realizations remain open with respect to `A` and are not
`ClosedPairPlus`. -/
def section4UBlueCondPairSet (C : ConstructionData n m) (I : Finset (Fin n))
    (A : Finset (BaseVertex m)) : Finset (Fin m √ó Fin m) := by
  classical
  exact (C.section4UBluePairSet I A).filter fun p =>
    ‚àÉ v ‚àà I, ‚àÉ w ‚àà I,
      C.blueProj v = p.1 ‚àß C.blueProj w = p.2 ‚àß
        v ‚âÝ w ‚àß C.OpenPairOn I A v w ‚àß C.OpenPairPlus I v w

/-- The combined conditioned `U_R ‚à™ U_B` object used in the exact Section 4 event count. -/
def section4UCondPairSet (C : ConstructionData n m) (I : Finset (Fin n))
    (A : Finset (BaseVertex m)) : Finset (BaseVertex m √ó BaseVertex m) := by
  classical
  exact
    ((C.section4URedCondPairSet I A).image fun p => (Sum.inl p.1, Sum.inl p.2)) ‚à™
      ((C.section4UBlueCondPairSet I A).image fun p => (Sum.inr p.1, Sum.inr p.2))

/-- The residual part of `T_I` after removing the exact conditioned `U_R ‚à™ U_B` pairs. Under the
independence event, these are the pairs that must be non-edges in the second-stage exposure. -/
def section4TRemainingPairSet (C : ConstructionData n m) (I : Finset (Fin n))
    (A : Finset (BaseVertex m)) : Finset (BaseVertex m √ó BaseVertex m) := by
  classical
  exact (C.section4TPairSet I A).filter fun p => p ‚àâ C.section4UCondPairSet I A

/-- Candidate red opposite-color witness choices of size `uR` for the conditioned `U_R`
event-counting layer. -/
def section4URedChoiceSet (C : ConstructionData n m) (I : Finset (Fin n))
    (A : Finset (BaseVertex m)) (uR : ‚Ñï) : Finset (Finset (Sym2 (Fin m))) :=
  (C.redOppositeWitnessBiUnion I A).powersetCard uR

/-- Candidate blue opposite-color witness choices of size `uB` for the conditioned `U_B`
event-counting layer. -/
def section4UBlueChoiceSet (C : ConstructionData n m) (I : Finset (Fin n))
    (A : Finset (BaseVertex m)) (uB : ‚Ñï) : Finset (Finset (Sym2 (Fin m))) :=
  (C.blueOppositeWitnessBiUnion I A).powersetCard uB

/-- The finite family of conditioned `(U_R,U_B)` witness choices of prescribed sizes. -/
def section4UChoiceSet (C : ConstructionData n m) (I : Finset (Fin n))
    (A : Finset (BaseVertex m)) (uR uB : ‚Ñï) :
    Finset (Finset (Sym2 (Fin m)) √ó Finset (Sym2 (Fin m))) :=
  C.section4URedChoiceSet I A uR √óÀ¢ C.section4UBlueChoiceSet I A uB

/-- The literal red second-stage sample space of size-`u_R` edge sets inside `T_R`. -/
def section4TRedChoiceSet (C : ConstructionData n m) (I : Finset (Fin n))
    (A : Finset (BaseVertex m)) (uR : ‚Ñï) : Finset (Finset (Sym2 (Fin m))) :=
  ((C.section4TRedPairSet I A).image Sym2.mk).powersetCard uR

/-- The literal blue second-stage sample space of size-`u_B` edge sets inside `T_B`. -/
def section4TBlueChoiceSet (C : ConstructionData n m) (I : Finset (Fin n))
    (A : Finset (BaseVertex m)) (uB : ‚Ñï) : Finset (Finset (Sym2 (Fin m))) :=
  ((C.section4TBluePairSet I A).image Sym2.mk).powersetCard uB

/-- The literal second-stage sample space of size-`(u_R,u_B)` edge outcomes inside `T_R √ó T_B`. -/
def section4TChoiceSet (C : ConstructionData n m) (I : Finset (Fin n))
    (A : Finset (BaseVertex m)) (uR uB : ‚Ñï) :
    Finset (Finset (Sym2 (Fin m)) √ó Finset (Sym2 (Fin m))) :=
  C.section4TRedChoiceSet I A uR √óÀ¢ C.section4TBlueChoiceSet I A uB

/-- The Bernoulli mass of a second-stage exposure pattern with `uR + uB` chosen edges and
`remaining` forced non-edges. -/
def section4BernoulliMass (p : ‚Ñù) (uR uB remaining : ‚Ñï) : ‚Ñù :=
  p ^ (uR + uB) * (1 - p) ^ remaining

/-- The finite Bernoulli mass of an explicit second-stage event family. -/
def section4SecondStageEventMass
    (E : Finset (Finset (Sym2 (Fin m)) √ó Finset (Sym2 (Fin m))))
    (p : ‚Ñù) (remaining : ‚Ñï) : ‚Ñù := by
  exact Finset.sum E fun outcome =>
    section4BernoulliMass p outcome.1.card outcome.2.card remaining

/-- The counted-event upper bound obtained by choosing a red/blue witness pattern and then forcing
all residual `T \ U` pairs to be non-edges. -/
def section4ChoiceMass (C : ConstructionData n m) (I : Finset (Fin n))
    (A : Finset (BaseVertex m)) (p : ‚Ñù) (uR uB remaining : ‚Ñï) : ‚Ñù :=
  ((C.section4UChoiceSet I A uR uB).card : ‚Ñù) * section4BernoulliMass p uR uB remaining

/-- The finite counted-event mass of the exact size-`(u_R,u_B)` witness family. -/
def section4ChoiceEventMass (C : ConstructionData n m) (I : Finset (Fin n))
    (A : Finset (BaseVertex m)) (p : ‚Ñù) (uR uB remaining : ‚Ñï) : ‚Ñù := by
  exact
    section4SecondStageEventMass (C.section4UChoiceSet I A uR uB) p remaining

/-- The finite index set for the possible `(u_R,u_B)` counts used in the summed `lem:RISI`
estimate. -/
def section4CountIndexSet (uRMax uBMax : ‚Ñï) : Finset (‚Ñï √ó ‚Ñï) :=
  Finset.range (uRMax + 1) √óÀ¢ Finset.range (uBMax + 1)

/-- The summed counted-event mass over all admissible `(u_R,u_B)` values. -/
def section4ChoiceEventMassSum (C : ConstructionData n m) (I : Finset (Fin n))
    (A : Finset (BaseVertex m)) (p : ‚Ñù) (remaining uRMax uBMax : ‚Ñï) : ‚Ñù := by
  exact
    Finset.sum (section4CountIndexSet uRMax uBMax) fun uv =>
      C.section4ChoiceEventMass I A p uv.1 uv.2 remaining

/-- The corresponding summed upper-bound expression after replacing the actual witness-family
cardinalities by projection-pair counts. -/
def section4ProjectionChoiceMassSum (p : ‚Ñù) (remaining uRMax uBMax : ‚Ñï) : ‚Ñù := by
  exact
    Finset.sum (section4CountIndexSet uRMax uBMax) fun uv =>
      ((((uRMax.choose uv.1 : ‚Ñï) : ‚Ñù) * p ^ uv.1) *
          (((uBMax.choose uv.2 : ‚Ñï) : ‚Ñù) * p ^ uv.2)) *
        (1 - p) ^ remaining

/-- The exact conditioned second-stage witness outcome produced by the current independent-set
configuration. -/
def section4UCondChoiceOutcome (C : ConstructionData n m) (I : Finset (Fin n))
    (A : Finset (BaseVertex m)) :
    Finset (Sym2 (Fin m)) √ó Finset (Sym2 (Fin m)) :=
  ((C.section4URedCondPairSet I A).image Sym2.mk,
    (C.section4UBlueCondPairSet I A).image Sym2.mk)

/-- The singleton counted-event object corresponding to the actual conditioned second-stage outcome
having prescribed red/blue witness counts. -/
def section4UCondChoiceEvent (C : ConstructionData n m) (I : Finset (Fin n))
    (A : Finset (BaseVertex m)) (uR uB : ‚Ñï) :
    Finset (Finset (Sym2 (Fin m)) √ó Finset (Sym2 (Fin m))) :=
  if (C.section4URedCondPairSet I A).card = uR ‚àß
      (C.section4UBlueCondPairSet I A).card = uB then
    {C.section4UCondChoiceOutcome I A}
  else
    ‚àÖ

/-- The counted mass of the exact conditioned second-stage event with prescribed `(u_R,u_B)`
counts. -/
def section4UCondChoiceEventMass (C : ConstructionData n m) (I : Finset (Fin n))
    (A : Finset (BaseVertex m)) (p : ‚Ñù) (uR uB remaining : ‚Ñï) : ‚Ñù := by
  exact
    section4SecondStageEventMass (C.section4UCondChoiceEvent I A uR uB) p remaining

/-- The summed mass of the actual conditioned event over all admissible `(u_R,u_B)` values. -/
def section4UCondChoiceEventMassSum (C : ConstructionData n m) (I : Finset (Fin n))
    (A : Finset (BaseVertex m)) (p : ‚Ñù) (remaining uRMax uBMax : ‚Ñï) : ‚Ñù := by
  exact
    Finset.sum (section4CountIndexSet uRMax uBMax) fun uv =>
      C.section4UCondChoiceEventMass I A p uv.1 uv.2 remaining

/-- The aggregate Section 4 loss term subtracted from a base open-pair lower bound before the
second-stage Bernoulli exposure: reveal budget, same-color `ClosedPairPlus`, and opposite-color
witness-cap contributions. -/
def section4SecondStageLossNat (C : ConstructionData n m) (I : Finset (Fin n)) (Œµ : ‚Ñù) : ‚Ñï :=
  I.card * (C.section4F1 I ‚à™ C.section4F2 I Œµ).card +
    (C.redProjectionPairCount I ((C.baseImage I).filter IsRedBaseVertex) +
      C.blueProjectionPairCount I ((C.baseImage I).filter IsBlueBaseVertex)) +
    C.redProjectionPairCount I
      ((Finset.univ.filter fun b : Fin m => Sum.inr b ‚àâ C.section4F I Œµ).image Sum.inr) +
    C.blueProjectionPairCount I
      ((Finset.univ.filter fun r : Fin m => Sum.inl r ‚àâ C.section4F I Œµ).image Sum.inl)

/-- The literal finite mass of the actual conditioned second-stage Section 4 event, obtained by
plugging the true `(u_R,u_B)` counts and the aggregate loss term into the explicit Bernoulli event
family. This is the repo-level stand-in for the conditioned probability in `lem:RISI`. -/
def section4ActualConditionedEventMass (C : ConstructionData n m) (I : Finset (Fin n))
    (Œµ p : ‚Ñù) (N : ‚Ñï) : ‚Ñù :=
  let uRActual := (C.section4URedCondPairSet I (C.section4F I Œµ)).card
  let uBActual := (C.section4UBlueCondPairSet I (C.section4F I Œµ)).card
  C.section4UCondChoiceEventMass I (C.section4F I Œµ) p uRActual uBActual
    (N - C.section4SecondStageLossNat I Œµ)

