    (hblueEq : ((C.blueImage I).card : ‚Ñù) = xB * (Twobites.paperKNat (1 + Œµ) n : ‚Ñù))
    (hxRpos : 0 < xR) (hxBpos : 0 < xB)
    (houterExp :
